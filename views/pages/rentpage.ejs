<%- include('../partials/head', { title, headExtras: '', extraScript: '' }) %>
<style>
*,
*::before,
*::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --br: #7B4B2A;
  --brd: #5A361D;
  --brl: #C9A27A;
  --brp: #F0E4D6;
  --bg: #F7F3EE;
  --bg2: #EFE6DB;
  --bg3: #E5D8C8;
  --bor: #DDD0C0;
  --tx: #231209;
  --tx2: #6B4838;
  --tx3: #9C7B66;
  --wh: #FFFFFF;
  --teal: #0D9488;
  --teald: #0F766E;
  --tealb: #F0FDFA;
  --teal-border: #99F6E4;
}

body {
  font-family: 'Sora', sans-serif;
  background: var(--bg);
  color: var(--tx);
}

/* NAV */
.nav {
  background: rgba(255, 255, 255, .92);
  backdrop-filter: blur(14px);
  border-bottom: 1px solid var(--bor);
  display: flex;
  align-items: center;
  padding: 0 28px;
  height: 60px;
  gap: 14px;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-logo {
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 10px;
}

.nav-logo-icon {
  width: 34px;
  height: 34px;
  border-radius: 9px;
  background: linear-gradient(135deg, var(--teal), var(--teald));
  color: #fff;
  font-weight: 800;
  font-size: 17px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-logo b {
  font-size: 17px;
  font-weight: 800;
  color: var(--br);
  display: block;
  line-height: 1.1;
}

.nav-logo small {
  font-size: 10px;
  color: var(--tx3);
  display: block;
}

.nav-r {
  margin-left: auto;
  display: flex;
  gap: 9px;
  align-items: center;
}

.nbtn {
  border: 1.5px solid var(--bor);
  cursor: pointer;
  border-radius: 9px;
  padding: 7px 15px;
  font-size: 12px;
  font-weight: 600;
  font-family: 'Sora', sans-serif;
  background: var(--bg2);
  color: var(--br);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  transition: .18s;
}

.nbtn:hover {
  background: var(--bg3);
}

.nbtn.teal {
  background: var(--tealb);
  color: var(--teal);
  border-color: var(--teal-border);
}

.nbtn.teal:hover {
  background: #CCFBF1;
  transform: translateY(-1px);
}

/* HERO */
.rent-hero {
  background: linear-gradient(130deg, #0D9488 0%, #0F766E 50%, #134E4A 100%);
  padding: 52px 28px 44px;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.rent-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 60% 80% at 15% 60%, rgba(255, 255, 255, .08), transparent 60%),
    radial-gradient(ellipse 40% 60% at 85% 20%, rgba(255, 255, 255, .06), transparent 50%);
}

.hero-particles {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.p {
  position: absolute;
  font-size: 24px;
  opacity: .15;
  animation: float 6s infinite ease-in-out;
}

.p1 {
  top: 15%;
  left: 8%;
  animation-delay: 0s;
}

.p2 {
  top: 20%;
  right: 12%;
  animation-delay: 1.5s;
}

.p3 {
  bottom: 25%;
  left: 15%;
  animation-delay: 3s;
}

.p4 {
  bottom: 20%;
  right: 8%;
  animation-delay: 4.5s;
}

@keyframes float {

  0%,
  100% {
    transform: translateY(0) rotate(-5deg)
  }

  50% {
    transform: translateY(-12px) rotate(5deg)
  }
}

.rent-hero-badge {
  display: inline-block;
  background: rgba(255, 255, 255, .15);
  border: 1px solid rgba(255, 255, 255, .25);
  color: rgba(255, 255, 255, .9);
  padding: 5px 16px;
  border-radius: 99px;
  font-size: 12px;
  font-weight: 600;
  margin-bottom: 14px;
  letter-spacing: .5px;
  animation: fadeUp .5s ease;
}

.rent-hero h1 {
  font-family: 'Lora', serif;
  font-size: 36px;
  color: #fff;
  margin-bottom: 10px;
  letter-spacing: -.5px;
  position: relative;
  animation: fadeUp .5s .1s both;
}

.rent-hero p {
  font-size: 14px;
  color: rgba(255, 255, 255, .75);
  max-width: 440px;
  margin: 0 auto 24px;
  position: relative;
  animation: fadeUp .5s .2s both;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(16px)
  }

  to {
    opacity: 1;
    transform: translateY(0)
  }
}

.hero-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24px;
  animation: fadeUp .5s .3s both;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat span {
  font-size: 22px;
  font-weight: 800;
  color: #fff;
}

.stat small {
  font-size: 11px;
  color: rgba(255, 255, 255, .65);
  margin-top: 2px;
}

.stat-div {
  width: 1px;
  height: 30px;
  background: rgba(255, 255, 255, .2);
}

/* FILTER */
.rent-filter {
  background: var(--wh);
  border-bottom: 1px solid var(--bor);
  padding: 14px 28px;
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  align-items: center;
  position: sticky;
  top: 60px;
  z-index: 90;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 9px;
  flex: 1;
  min-width: 200px;
  background: var(--bg);
  border: 1.5px solid var(--bor);
  border-radius: 10px;
  padding: 9px 13px;
  transition: .2s;
}

.search-box:focus-within {
  border-color: var(--teal-border);
  background: #fff;
}

.search-box input {
  border: none;
  background: none;
  outline: none;
  font-family: 'Sora', sans-serif;
  font-size: 13px;
  flex: 1;
}

.fchip {
  padding: 7px 15px;
  border-radius: 99px;
  font-size: 12px;
  font-weight: 600;
  font-family: 'Sora', sans-serif;
  border: 1.5px solid var(--bor);
  background: var(--wh);
  color: var(--tx3);
  cursor: pointer;
  transition: .18s;
}

.fchip:hover {
  background: var(--bg2);
  border-color: var(--teal-border);
  color: var(--teal);
}

.fchip.on {
  background: var(--teal);
  color: #fff;
  border-color: var(--teal);
}

/* GRID */
.rent-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 22px;
  padding: 28px;
}

/* CARD */
.rent-card {
  background: var(--wh);
  border: 1.5px solid var(--bor);
  border-radius: 18px;
  overflow: hidden;
  cursor: pointer;
  transition: .25s cubic-bezier(.34, 1.2, .64, 1);
  animation: cardRise .4s ease both;
}

@keyframes cardRise {
  from {
    opacity: 0;
    transform: translateY(16px)
  }

  to {
    opacity: 1;
    transform: translateY(0)
  }
}

.rent-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 48px rgba(13, 148, 136, .15);
  border-color: var(--teal-border);
}

.rent-img {
  height: 175px;
  background: var(--tealb);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44px;
  position: relative;
}

.rent-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: .4s;
}

.rent-card:hover .rent-img img {
  transform: scale(1.05);
}

.rent-badge {
  position: absolute;
  top: 10px;
  left: 10px;
  background: rgba(13, 148, 136, .85);
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  padding: 4px 11px;
  border-radius: 99px;
  backdrop-filter: blur(4px);
}

.rent-avail {
  position: absolute;
  top: 10px;
  right: 10px;
  font-size: 10px;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: 99px;
}

.avail-yes {
  background: #dcfce7;
  color: #166534;
}

.avail-no {
  background: #fee2e2;
  color: #991b1b;
}

.rent-body {
  padding: 16px 18px 14px;
}

.rent-title {
  font-size: 14px;
  font-weight: 700;
  margin-bottom: 8px;
}

.rent-price-row {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 10px;
}

.rent-price {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: var(--tealb);
  color: var(--teal);
  border: 1px solid var(--teal-border);
  padding: 5px 12px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 700;
}

.rent-price-day {
  background: var(--brp);
  color: var(--br);
  border: 1px solid var(--brl);
}

.rent-meta {
  font-size: 12px;
  color: var(--tx3);
  line-height: 1.7;
  margin-bottom: 12px;
}

.rent-footer {
  display: flex;
  gap: 8px;
}

.btn-rent {
  flex: 1;
  background: linear-gradient(135deg, var(--teal), var(--teald));
  color: #fff;
  border: none;
  padding: 10px;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 700;
  font-family: 'Sora', sans-serif;
  cursor: pointer;
  transition: .2s;
}

.btn-rent:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 14px rgba(13, 148, 136, .3);
}

.btn-wish {
  background: var(--bg2);
  border: 1.5px solid var(--bor);
  border-radius: 10px;
  padding: 10px 14px;
  font-size: 14px;
  cursor: pointer;
  transition: .18s;
}

.btn-wish:hover {
  background: #ffe4e4;
  border-color: #f9a8a8;
}

/* MODAL */
.modal-ov {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(15, 8, 3, .6);
  backdrop-filter: blur(6px);
  z-index: 500;
  align-items: center;
  justify-content: center;
  padding: 16px;
}

.modal-ov.on {
  display: flex;
}

.modal-box {
  background: var(--wh);
  border-radius: 22px;
  width: 100%;
  max-width: 680px;
  max-height: 92vh;
  overflow-y: auto;
  box-shadow: 0 40px 100px rgba(0, 0, 0, .3);
  animation: modIn .28s cubic-bezier(.34, 1.4, .64, 1);
}

@keyframes modIn {
  from {
    transform: scale(.9);
    opacity: 0
  }

  to {
    transform: scale(1);
    opacity: 1
  }
}

.modal-img {
  width: 100%;
  height: 270px;
  background: var(--tealb);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64px;
  overflow: hidden;
}

.modal-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.modal-content {
  padding: 26px 28px 28px;
}

.modal-title {
  font-size: 22px;
  font-weight: 800;
  margin-bottom: 6px;
}

.modal-seller {
  font-size: 13px;
  color: var(--tx3);
  margin-bottom: 20px;
}

.price-boxes {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 22px;
}

.price-box {
  flex: 1;
  min-width: 130px;
  border: 1.5px solid var(--bor);
  border-radius: 14px;
  padding: 16px;
  text-align: center;
  transition: .2s;
}

.price-box:hover {
  border-color: var(--teal-border);
  transform: translateY(-2px);
}

.price-box.teal {
  border-color: var(--teal-border);
  background: var(--tealb);
}

.price-box-lbl {
  font-size: 10px;
  font-weight: 700;
  color: var(--tx3);
  text-transform: uppercase;
  letter-spacing: .5px;
  margin-bottom: 8px;
}

.price-box-val {
  font-size: 26px;
  font-weight: 800;
  color: var(--teal);
}

.price-box-sub {
  font-size: 11px;
  color: var(--tx3);
  margin-top: 3px;
}

.modal-section {
  margin-bottom: 20px;
}

.modal-section h4 {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .6px;
  color: var(--tx3);
  margin-bottom: 10px;
}

.modal-section p {
  font-size: 13px;
  color: var(--tx2);
  line-height: 1.75;
}

.modal-info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.info-item {
  background: var(--bg);
  border: 1px solid var(--bor);
  border-radius: 11px;
  padding: 12px 14px;
}

.info-item-lbl {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .4px;
  color: var(--tx3);
  margin-bottom: 5px;
}

.info-item-val {
  font-size: 13px;
  font-weight: 600;
}

/* Rent form */
.rent-form {
  background: var(--bg);
  border: 1.5px solid var(--bor);
  border-radius: 14px;
  padding: 20px;
  margin-top: 22px;
}

.rent-form h4 {
  font-size: 14px;
  font-weight: 700;
  margin-bottom: 18px;
  color: var(--teal);
}

.fg {
  margin-bottom: 14px;
}

.fg label {
  display: block;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .5px;
  color: var(--tx3);
  margin-bottom: 7px;
}

.fg input,
.fg select,
.fg textarea {
  width: 100%;
  padding: 11px 13px;
  border: 1.5px solid var(--bor);
  border-radius: 10px;
  font-size: 13px;
  font-family: 'Sora', sans-serif;
  background: var(--wh);
  color: var(--tx);
  outline: none;
  transition: .15s;
}

.fg input:focus,
.fg select:focus,
.fg textarea:focus {
  border-color: var(--teal-border);
  box-shadow: 0 0 0 3px rgba(13, 148, 136, .08);
}

.fg-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.cost-preview {
  background: var(--tealb);
  border: 1.5px solid var(--teal-border);
  border-radius: 12px;
  padding: 14px 18px;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cost-preview-lbl {
  font-size: 12px;
  color: var(--teal);
  font-weight: 600;
}

.cost-preview-val {
  font-size: 22px;
  font-weight: 800;
  color: var(--teal);
}

/* modal header */
.modal-header {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 14px 18px 0;
}

.close-x {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  border: none;
  background: var(--bg2);
  color: var(--tx2);
  font-size: 20px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: .18s;
}

.close-x:hover {
  background: var(--bg3);
  transform: rotate(90deg);
}

/* empty */
.empty-state {
  grid-column: 1/-1;
  text-align: center;
  padding: 70px 20px;
  color: var(--tx3);
}

.empty-state .ei {
  font-size: 52px;
  margin-bottom: 14px;
}

.empty-state h4 {
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 6px;
  color: var(--tx2);
}

/* toast */
.toast {
  position: fixed;
  bottom: 26px;
  left: 50%;
  transform: translateX(-50%) translateY(60px);
  background: var(--tx);
  color: #fff;
  padding: 12px 26px;
  border-radius: 99px;
  font-size: 13px;
  font-weight: 600;
  opacity: 0;
  transition: .3s ease;
  z-index: 999;
  white-space: nowrap;
  box-shadow: 0 6px 24px rgba(0, 0, 0, .25);
}

.toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

@media(max-width:700px) {
  .rent-grid {
    grid-template-columns: 1fr;
    padding: 16px;
  }

  .modal-info-grid,
  .fg-row {
    grid-template-columns: 1fr;
  }

  .price-boxes {
    flex-direction: column;
  }

  .hero-stats {
    display: none;
  }
}

/* ── Account dropdown (matches marketplace nav style) ── */
.nav-r {
  margin-left: auto;
  display: flex;
  gap: 9px;
  align-items: center;
}

.profile-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 12px;
  border-radius: 10px;
  background: var(--bg2);
  border: 1.5px solid var(--bor);
  cursor: pointer;
  font-family: 'Sora', sans-serif;
  font-size: 13px;
  font-weight: 600;
  color: var(--br);
  transition: .18s;
  position: relative;
}

.profile-btn:hover {
  background: var(--bg3);
}

.profile-avatar {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--brl, #C9A27A), var(--br));
  color: #fff;
  font-size: 13px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.profile-dropdown {
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  background: #fff;
  border: 1.5px solid var(--bor);
  border-radius: 14px;
  width: 220px;
  box-shadow: 0 12px 36px rgba(123, 75, 42, .14);
  z-index: 300;
  display: none;
  overflow: hidden;
  animation: dropIn .18s ease;
}

@keyframes dropIn {
  from {
    opacity: 0;
    transform: translateY(-8px)
  }

  to {
    opacity: 1;
    transform: none
  }
}

.profile-dropdown.open {
  display: block;
}

.drop-header {
  padding: 14px 16px;
  background: var(--bg2);
  border-bottom: 1px solid var(--bor);
}

.drop-name {
  font-size: 14px;
  font-weight: 800;
  color: var(--tx);
}

.drop-email {
  font-size: 11px;
  color: var(--tx3);
  margin-top: 2px;
}

.drop-item {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 11px 16px;
  font-size: 13px;
  font-weight: 600;
  color: var(--tx2);
  text-decoration: none;
  cursor: pointer;
  transition: .15s;
  border-bottom: 1px solid var(--bg2);
}

.drop-item:last-child {
  border-bottom: none;
}

.drop-item:hover {
  background: var(--bg2);
  color: var(--br);
}

.drop-item.danger {
  color: #B83232;
}

.drop-item.danger:hover {
  background: #FDEAEA;
}

.drop-signin {
  padding: 18px;
  text-align: center;
}

.drop-signin p {
  font-size: 12px;
  color: var(--tx3);
  margin-bottom: 12px;
}

.sign-in-btn {
  width: 100%;
  padding: 9px;
  background: var(--br);
  color: #fff;
  border: none;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 700;
  font-family: 'Sora', sans-serif;
  cursor: pointer;
}


/* Mobile nav fix for rentpage */
@media (max-width: 600px) {
  .nav {
    padding: 0 12px;
    height: 52px;
    gap: 8px;
  }

  .nav-logo-icon {
    width: 28px;
    height: 28px;
    font-size: 14px;
  }

  .nav-logo b {
    font-size: 14px;
  }

  .nav-logo small {
    display: none;
  }

  .nav-r {
    gap: 5px;
  }

  .nbtn {
    padding: 5px 9px;
    font-size: 11px;
  }

  .nbtn:first-of-type {
    display: none;
  }

  /* hide Marketplace link */
  /* Filter strip scrolls */
  .rent-filter {
    flex-wrap: nowrap;
    overflow-x: auto;
    scrollbar-width: none;
    padding: 8px 12px;
  }

  .rent-filter::-webkit-scrollbar {
    display: none;
  }

  .search-box {
    min-width: 140px;
    flex-shrink: 0;
  }

  .fchip {
    flex-shrink: 0;
  }

  /* Rent grid 2 col */
  .rent-grid {
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 12px;
    padding: 12px;
  }

  .rent-img {
    height: 120px;
  }

  .rent-title {
    font-size: 12px;
  }
}

@media (max-width: 380px) {
  .rent-grid {
    grid-template-columns: 1fr !important;
  }
}

/* Modal full screen on mobile */
@media (max-width: 600px) {
  .modal-ov {
    padding: 0;
    align-items: flex-end;
  }

  .modal-box {
    border-radius: 20px 20px 0 0;
    max-height: 92vh;
    width: 100%;
    max-width: 100%;
  }

  .modal-img {
    height: 180px;
  }

  .fg-row {
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .price-boxes {
    flex-direction: column;
  }

  .modal-info-grid {
    grid-template-columns: 1fr 1fr;
  }
}
</style>

<nav class="nav">
    <a href="/marketplace" class="nav-logo">
      <div class="nav-logo-icon">S</div>
      <div>
        <b>StudXchange</b>
        <small>Academic Marketplace</small>
      </div>
    </a>
    <div class="nav-r">
      <a href="/marketplace" class="nbtn">← Marketplace</a>
      <button class="nbtn teal" onclick="goPostRent()">+ List for Rent</button>
      <!-- Account Button -->
      <div style="position:relative">
        <button class="profile-btn" id="profileBtn" onclick="toggleDrop()">
          <div class="profile-avatar" id="profileAvatar">?</div>
          <span id="profileLabel">Account</span>
          <span style="font-size:10px;opacity:.7">▾</span>
        </button>
        <div class="profile-dropdown" id="profileDropdown">
          <!-- signed-out state -->
          <div id="dropSignedOut" class="drop-signin">
            <p>Sign in to save items and list rentals.</p>
            <button class="sign-in-btn" onclick="location.href='/login'">Sign In</button>
          </div>
          <!-- signed-in state -->
          <div id="dropSignedIn" style="display:none">
            <div class="drop-header">
              <div class="drop-name" id="dropName">—</div>
              <div class="drop-email" id="dropEmail">—</div>
            </div>
            <a class="drop-item" href="/myprofile">👤 My Profile</a>
            <a class="drop-item" href="/chat">💬 Chats</a>
            <span class="drop-item danger" onclick="signOut()">🚪 Sign Out</span>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <div class="rent-hero">
    <div class="hero-particles">
      <span class="p p1">📚</span>
      <span class="p p2">💻</span>
      <span class="p p3">🚲</span>
      <span class="p p4">🪑</span>
    </div>
    <div class="rent-hero-badge">🔄 Rent & Borrow</div>
    <h1>Rent from Students</h1>
    <p>Borrow what you need, rent out what you have — save money together</p>
    <div class="hero-stats">
      <div class="stat"><span id="statCount">—</span><small>Listings</small></div>
      <div class="stat-div"></div>
      <div class="stat"><span>100%</span><small>Student-to-Student</small></div>
    </div>
  </div>

  <div class="rent-filter">
    <div class="search-box">
      <span>🔍</span>
      <input type="text" id="searchInput" placeholder="Search rent listings…" oninput="filterItems()">
    </div>
    <button class="fchip on" onclick="setFilter('all',this)">✨ All</button>
    <button class="fchip" onclick="setFilter('Books',this)">📚 Books</button>
    <button class="fchip" onclick="setFilter('Laptops',this)">💻 Laptops</button>
    <button class="fchip" onclick="setFilter('Electronics',this)">📱 Electronics</button>
    <button class="fchip" onclick="setFilter('Bikes',this)">🚲 Bikes</button>
    <button class="fchip" onclick="setFilter('Furniture',this)">🪑 Furniture</button>
    <button class="fchip" onclick="setFilter('Other',this)">🎒 Other</button>
  </div>

  <div id="rentGrid" class="rent-grid"></div>

  <!-- DETAIL MODAL -->
  <div class="modal-ov" id="rentModal" onclick="if(event.target===this)closeModal()">
    <div class="modal-box" id="rentModalBox">
      <div class="modal-header">
        <button class="close-x" onclick="closeModal()">×</button>
      </div>
      <div id="rentModalContent"></div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

<script>

const user   = JSON.parse(localStorage.getItem("user"));
let allItems  = [];
let activeFilter = "all";

// ── Nav account setup ─────────────────────────────────────────────────────────
function setupNav() {
  const btn   = document.getElementById("profileBtn");
  const avDiv = document.getElementById("profileAvatar");
  const lbl   = document.getElementById("profileLabel");
  const out   = document.getElementById("dropSignedOut");
  const inn   = document.getElementById("dropSignedIn");

  if (user) {
    const initials = (user.name || "?").trim().split(/\s+/).map(w => w[0]).join("").toUpperCase().slice(0,2);
    avDiv.textContent = initials;
    lbl.textContent   = user.name.split(" ")[0];
    out.style.display = "none";
    inn.style.display = "block";
    document.getElementById("dropName").textContent  = user.name;
    document.getElementById("dropEmail").textContent = user.email;
  } else {
    avDiv.textContent = "?";
    lbl.textContent   = "Account";
  }
}

function toggleDrop() {
  document.getElementById("profileDropdown").classList.toggle("open");
}

// Close dropdown on outside click
document.addEventListener("click", e => {
  const btn  = document.getElementById("profileBtn");
  const drop = document.getElementById("profileDropdown");
  if (!btn.contains(e.target) && !drop.contains(e.target)) {
    drop.classList.remove("open");
  }
});

function signOut() {
  localStorage.removeItem("user");
  window.location.href = "/login";
}

// ── Helpers ───────────────────────────────────────────────────────────────────
function toast(msg) {
  const t = document.getElementById("toast");
  t.textContent = msg;
  t.classList.add("show");
  setTimeout(() => t.classList.remove("show"), 2800);
}

function goPostRent() {
  if (!user) { toast("Please sign in to list a rental"); setTimeout(() => location.href="/login", 1500); return; }
  location.href = "/rent";
}

function setFilter(cat, el) {
  activeFilter = cat;
  document.querySelectorAll(".fchip").forEach(c => c.classList.remove("on"));
  el.classList.add("on");
  filterItems();
}

function filterItems() {
  const q = (document.getElementById("searchInput").value || "").toLowerCase();
  let list = allItems;
  if (activeFilter !== "all") list = list.filter(i => i.category === activeFilter);
  if (q) list = list.filter(i => i.title.toLowerCase().includes(q) || (i.description||'').toLowerCase().includes(q));
  renderGrid(list);
}

// ── Load from server ──────────────────────────────────────────────────────────
async function loadRentals() {
  const grid = document.getElementById("rentGrid");
  grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:60px 20px;color:var(--tx3)"><div style="font-size:32px;margin-bottom:10px;animation:float 2s infinite ease-in-out">🔄</div><p>Loading rentals…</p></div>`;
  try {
    const res  = await fetch(`/rent-products`);
    allItems   = await res.json();
    const sc = document.getElementById("statCount");
    if (sc) sc.textContent = allItems.length;
    renderGrid(allItems);
  } catch {
    grid.innerHTML = `<div class="empty-state" style="grid-column:1/-1"><div class="ei">⚠️</div><h4>Could not connect</h4><p>Make sure your server is running with <b>node server.js</b></p></div>`;
  }
}

function renderGrid(list) {
  const grid = document.getElementById("rentGrid");
  if (!list.length) {
    grid.innerHTML = `<div class="empty-state" style="grid-column:1/-1"><div class="ei">🔄</div><h4>No rentals yet</h4><p>Be the first to list something for rent!</p></div>`;
    return;
  }
  grid.innerHTML = list.map((item, i) => `
    <div class="rent-card" style="animation-delay:${i*0.05}s" onclick="openDetail('${item._id||item.id}')">
      <div class="rent-img">
        ${item.image ? `<img src="${item.image}" alt="${item.title}" loading="lazy" onerror="this.style.display='none'">` : "🔄"}
        <span class="rent-badge">RENT</span>
        <span class="rent-avail ${item.is_available ? 'avail-yes' : 'avail-no'}">
          ${item.is_available ? '✅ Available' : '❌ Rented'}
        </span>
      </div>
      <div class="rent-body">
        <div class="rent-title">${item.title}</div>
        <div class="rent-price-row">
          ${item.rent_per_day ? `<span class="rent-price rent-price-day">₹${item.rent_per_day}/day</span>` : ""}
        </div>
        <div class="rent-meta">🏷 ${item.category} • 💰 Deposit: ₹${item.deposit || 0}<br>👤 ${item.seller_name}</div>
        <div class="rent-footer" onclick="event.stopPropagation()">
          <button class="btn-rent" onclick="openDetail('${item._id||item.id}')">View & Rent</button>
         <button 
  onclick="addRentToWishlist(event, '${item._id||item.id}')"
  style="
    padding: 8px 14px;
    border-radius: 10px;
    border: 1px solid #e2d3c3;
    background: #fff7ed;
    color: #7B4B2A;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.25s ease;
  "
  onmouseover="this.style.background='#7B4B2A'; this.style.color='#fff'; this.style.transform='scale(1.05)'"
  onmouseout="this.style.background='#fff7ed'; this.style.color='#7B4B2A'; this.style.transform='scale(1)'"
>
  ♡ Wishlist
</button>
        </div>
      </div>
    </div>`).join("");
}

async function openDetail(id) {
  const modal = document.getElementById("rentModal");
  modal.classList.add("on");
  document.body.style.overflow = "hidden";
  const item = allItems.find(i => String(i._id||i.id) === String(id));
  if (!item) return;
  const isOwn = user && getUserId(user) === item.seller_id;

  document.getElementById("rentModalContent").innerHTML = `
    <div class="modal-img">
      ${item.image ? `<img src="${item.image}" alt="${item.title}" onerror="this.style.display='none'">` : "🔄"}
    </div>
    <div class="modal-content">
      <div class="modal-title">${item.title}</div>
      <div class="modal-seller">👤 Listed by <b>${item.seller_name}</b> &nbsp;•&nbsp; 🏷 ${item.category}</div>
      <div class="price-boxes">
        ${item.rent_per_day ? `<div class="price-box teal">
          <div class="price-box-lbl">Per Day</div>
          <div class="price-box-val">₹${item.rent_per_day}</div>
          <div class="price-box-sub">Daily rate</div>
        </div>` : ""}
        ${item.deposit ? `<div class="price-box">
          <div class="price-box-lbl">Security Deposit</div>
          <div class="price-box-val" style="color:var(--br)">₹${item.deposit}</div>
          <div class="price-box-sub">Refundable</div>
        </div>` : ""}
      </div>
      <div class="modal-section">
        <h4>Description</h4>
        <p>${item.description || "No description provided."}</p>
      </div>
      <div class="modal-section">
        <h4>Item Details</h4>
        <div class="modal-info-grid">
          <div class="info-item"><div class="info-item-lbl">Availability</div><div class="info-item-val">${item.is_available ? "✅ Available" : "❌ Rented Out"}</div></div>
          <div class="info-item"><div class="info-item-lbl">Category</div><div class="info-item-val">🏷 ${item.category}</div></div>
          <div class="info-item"><div class="info-item-lbl">Contact</div><div class="info-item-val">📞 ${item.contact || "—"}</div></div>
          <div class="info-item"><div class="info-item-lbl">Listed By</div><div class="info-item-val">👤 ${item.seller_name}</div></div>
        </div>
      </div>
      ${isOwn
        ? `<p style="text-align:center;color:var(--tx3);font-size:13px;padding:16px;background:var(--bg);border-radius:12px">This is your listing.</p>`
        : !item.is_available
        ? `<p style="text-align:center;padding:16px;background:#fee2e2;border-radius:12px;color:#991b1b;font-size:13px;font-weight:600">❌ This item is currently rented out</p>`
        : `<div class="rent-form">
            <h4>🗓️ Request to Rent</h4>
            <div class="fg-row">
              <div class="fg"><label>Start Date</label><input type="date" id="rd-start" onchange="calcCost(${item.rent_per_day||0})" min="${new Date().toISOString().split('T')[0]}"></div>
              <div class="fg"><label>End Date</label><input type="date" id="rd-end" onchange="calcCost(${item.rent_per_day||0})" min="${new Date().toISOString().split('T')[0]}"></div>
            </div>
            <div class="cost-preview" id="costPreview" style="display:none">
              <span class="cost-preview-lbl">Estimated Cost</span>
              <span class="cost-preview-val" id="costVal">₹0</span>
            </div>
            <div class="fg"><label>Message to Owner (optional)</label><textarea id="rd-msg" rows="2" placeholder="e.g. I need this for a college project…"></textarea></div>
            <button class="btn-rent" style="width:100%;margin-top:4px" onclick="sendRentRequest('${item._id||item.id}','${item.seller_id}',${item.rent_per_day||0})">
              🔄 Send Rent Request
            </button>
          </div>`
      }
    </div>`;
}

function calcCost(perDay) {
  const s = document.getElementById("rd-start")?.value;
  const e = document.getElementById("rd-end")?.value;
  const preview = document.getElementById("costPreview");
  if (!s || !e || !preview) return;
  const days = Math.max(1, Math.ceil((new Date(e) - new Date(s)) / 86400000));
  document.getElementById("costVal").textContent = `₹${days*perDay} (${days} day${days>1?'s':''})`;
  preview.style.display = "flex";
}

async function sendRentRequest(productId, ownerId, perDay) {
  if (!user) { toast("Please sign in first"); setTimeout(() => location.href="/login",1500); return; }
  const start = document.getElementById("rd-start").value;
  const end   = document.getElementById("rd-end").value;
  const msg   = document.getElementById("rd-msg")?.value?.trim()||"";
  if (!start || !end) { toast("Please select start and end dates"); return; }
  if (new Date(end) <= new Date(start)) { toast("End date must be after start date"); return; }
  const days  = Math.ceil((new Date(end) - new Date(start)) / 86400000);
  const total = days * perDay;
  try {
    const res  = await fetch(`/send-rent-request`, {
      method:"POST", headers:{ "Authorization": "Bearer " + getToken(),"Content-Type":"application/json"},
      body: JSON.stringify({ renter_id:getUserId(user), owner_id:ownerId, product_id:productId, start_date:start, end_date:end, total_cost:total, message:msg })
    });
    const data = await res.json();
    if (data.success) { toast("Rent request sent! ✅"); closeModal(); }
    else toast(data.error || "Could not send request");
  } catch { toast("Server error"); }
}

function addWishlist(e, itemId) {
  e.stopPropagation();
  if (!user) { toast("Sign in to save to wishlist"); setTimeout(()=>location.href="/login",1500); return; }
  fetch(`/add-to-wishlist`, {
    method:"POST", headers:{ "Authorization": "Bearer " + getToken(),"Content-Type":"application/json"},
    body: JSON.stringify({ user_id:getUserId(user), item_id:itemId, item_type:"rent" })
  }).then(r=>r.json()).then(d => {
    if (d.success) {
      toast("Saved to wishlist ❤️");
      const btn = document.getElementById(`wish-${itemId}`);
      if (btn) { btn.textContent = "❤️"; btn.style.background = "#ffe4e4"; }
    } else {
      toast(d.message || d.error || "Already in wishlist");
    }
  }).catch(() => toast("Could not save"));
}

function closeModal() {
  document.getElementById("rentModal").classList.remove("on");
  document.body.style.overflow = "";
}

// ── INIT ──────────────────────────────────────────────────────────────────────
setupNav();
loadRentals();

function addRentToWishlist(e, rentId) {
  e.stopPropagation();

  if (!user) {
    toast("Please sign in first");
    setTimeout(() => location.href = "/login", 1500);
    return;
  }

  fetch(`/wishlist`, {
    method: "POST",
    headers: { "Content-Type": "application/json", "Authorization": "Bearer " + getToken() },
    body: JSON.stringify({
      user_id: getUserId(user),
      item_id: rentId,
      item_type: "rent"
    })
  })
    .then(r => r.json())
    .then(d => toast(d.success ? "Added to wishlist ❤️" : "Already in wishlist"))
    .catch(() => toast("Wishlist failed"));
}

</script>

