        <div class="ch">
          <h3>About Me</h3>
          <span class="che" onclick="openEdit()">Edit ✏️</span>
        </div>
        <div class="cb">
          <div class="ar">
            <div class="ar-ic">👤</div>
            <div>
              <div class="ar-lb">Name</div>
              <div class="ar-v" id="abN">—</div>
            </div>
          </div>
          <div class="ar">
            <div class="ar-ic">📧</div>
            <div>
              <div class="ar-lb">Email</div>
              <div class="ar-v" id="abE">—</div>
            </div>
