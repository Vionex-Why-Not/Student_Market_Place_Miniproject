        <div class="fg"><label>Course & Year</label><input id="fCourse" placeholder="e.g. B.Tech CSE — 3rd Year"></div>
        <div class="fg"><label>Location</label><input id="fLoc" placeholder="e.g. Pune, Maharashtra"></div>
