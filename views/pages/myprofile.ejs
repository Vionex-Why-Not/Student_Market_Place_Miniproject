<%- include('../partials/head', { title, headExtras: '', extraScript: '' }) %>
<style>
*,
*::before,
*::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --br: #7B4B2A;
  --brd: #5A361D;
  --brl: #C9A27A;
  --bg: #F7F3EE;
  --bg2: #EFE6DB;
  --bg3: #E5D8C8;
  --bor: #DDD0C0;
  --tx: #231209;
  --tx2: #6B4838;
  --tx3: #9C7B66;
  --wh: #FFFFFF;
  --gr: #276840;
  --grb: #E8F5ED;
  --rd: #B83232;
  --rdb: #FDEAEA;
  --amb: #FEF3DC;
  --am: #A06B10;
}

body {
  font-family: 'Sora', sans-serif;
  background: var(--bg);
  color: var(--tx);
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

/* NAV */
.nav {
  position: sticky;
  top: 0;
  z-index: 200;
  background: var(--wh);
  border-bottom: 1px solid var(--bor);
  display: flex;
  align-items: center;
  padding: 0 32px;
  height: 60px;
  gap: 12px;
}

.nav-logo {
  text-decoration: none;
  display: flex;
  flex-direction: column;
}

.nav-logo b {
  font-size: 18px;
  font-weight: 800;
  color: var(--br);
}

.nav-logo small {
  font-size: 10px;
  color: var(--tx3);
}

.nav-r {
  margin-left: auto;
  display: flex;
  gap: 9px;
}

.btn {
  border: none;
  cursor: pointer;
  border-radius: 9px;
  padding: 8px 16px;
  font-size: 12px;
  font-weight: 700;
  font-family: 'Sora', sans-serif;
  transition: .18s;
}

.btn-g {
  background: var(--bg2);
  color: var(--br);
  border: 1px solid var(--bor);
}

.btn-g:hover {
  background: var(--bg3);
}

.btn-m {
  background: var(--br);
  color: var(--wh);
}

.btn-m:hover {
  background: var(--brd);
}

.btn-d {
  background: var(--rdb);
  color: var(--rd);
  border: 1px solid #F0C0C0;
}

.btn-d:hover {
  background: #FADBDB;
}

/* BANNER */
.band {
  height: 195px;
  background: linear-gradient(130deg, #D4A574 0%, var(--br) 55%, #3A1E0C 100%);
  position: relative;
  overflow: hidden;
}

.band::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 60% 80% at 15% 60%, rgba(255, 255, 255, .1) 0%, transparent 60%), radial-gradient(ellipse 40% 60% at 85% 20%, rgba(255, 255, 255, .07) 0%, transparent 50%);
}

/* PROFILE HEADER */
.ph-wrap {
  max-width: 1020px;
  margin: 0 auto;
  padding: 0 32px;
}

/* Avatar floats up over banner, then name sits cleanly below */
.av-float {
  margin-top: -58px;
  margin-bottom: 16px;
}

.av {
  width: 112px;
  height: 112px;
  border-radius: 50%;
  background: linear-gradient(145deg, var(--brl), var(--brd));
  border: 4px solid var(--wh);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6px 28px rgba(43, 27, 18, .2);
}

.av-l {
  font-family: 'Lora', serif;
  font-size: 38px;
  font-weight: 700;
  color: var(--wh);
  letter-spacing: -1px;
}

/* Name + actions row fully below avatar */
.ph-name-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 14px;
  padding-bottom: 24px;
}

.user-name {
  font-family: 'Lora', serif;
  font-size: 27px;
  font-weight: 700;
  color: var(--tx);
  letter-spacing: -.3px;
  line-height: 1.2;
}

.pills {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
  margin-top: 9px;
}

.pill {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: var(--wh);
  border: 1px solid var(--bor);
  padding: 4px 12px;
  border-radius: 99px;
  font-size: 11px;
  color: var(--tx2);
  font-weight: 500;
}

.ph-actions {
  display: flex;
  gap: 9px;
  padding-top: 4px;
}

/* PAGE GRID */
.pg {
  max-width: 1020px;
  margin: 0 auto 70px;
  padding: 0 32px;
  display: grid;
  grid-template-columns: 268px 1fr;
  gap: 24px;
  margin-top: 0;
}

/* SIDEBAR CARD */
.card {
  background: var(--wh);
  border: 1px solid var(--bor);
  border-radius: 14px;
  overflow: hidden;
  margin-bottom: 16px;
  box-shadow: 0 2px 12px rgba(43, 27, 18, .06);
}

.ch {
  padding: 14px 18px;
  border-bottom: 1px solid var(--bor);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.ch h3 {
  font-size: 13px;
  font-weight: 700;
}

.che {
  font-size: 12px;
  font-weight: 600;
  color: var(--br);
  cursor: pointer;
}

.che:hover {
  text-decoration: underline;
}

.cb {
  padding: 16px 18px;
}

.ar {
  display: flex;
  gap: 11px;
  margin-bottom: 13px;
  align-items: flex-start;
}

.ar:last-child {
  margin-bottom: 0;
}

.ar-ic {
  font-size: 15px;
  margin-top: 1px;
  flex-shrink: 0;
}

.ar-lb {
  font-size: 10px;
  color: var(--tx3);
  text-transform: uppercase;
  letter-spacing: .5px;
  margin-bottom: 2px;
}

.ar-v {
  font-size: 13px;
  font-weight: 500;
  line-height: 1.5;
}

.ar-v.mt {
  color: var(--tx3);
  font-style: italic;
  font-weight: 400;
}

/* TABS */
.tabs {
  display: flex;
  gap: 3px;
  background: var(--wh);
  border: 1px solid var(--bor);
  border-radius: 11px;
  padding: 4px;
  margin-bottom: 22px;
  overflow-x: auto;
}

.tb-btn {
  flex: 1;
  min-width: max-content;
  padding: 9px 12px;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  color: var(--tx3);
  background: none;
  border: none;
  font-family: 'Sora', sans-serif;
  transition: .2s;
  white-space: nowrap;
}

.tb-btn.on {
  background: var(--br);
  color: var(--wh);
}

.tb-btn:hover:not(.on) {
  background: var(--bg2);
}

.pane {
  display: none;
}

.pane.on {
  display: block;
}

.pane-lbl {
  font-size: 11px;
  font-weight: 700;
  color: var(--tx3);
  text-transform: uppercase;
  letter-spacing: .6px;
  margin-bottom: 16px;
}

/* LISTING CARDS */
.lg {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 13px;
}

.lc {
  background: var(--wh);
  border: 1px solid var(--bor);
  border-radius: 13px;
  overflow: hidden;
  transition: .2s;
}

.lc:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(43, 27, 18, .1);
}

.lc-i {
  height: 115px;
  background: var(--bg2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38px;
  position: relative;
}

.lc-b {
  position: absolute;
  top: 9px;
  right: 9px;
  padding: 3px 9px;
  border-radius: 99px;
  font-size: 10px;
  font-weight: 700;
}

.ba {
  background: var(--grb);
  color: var(--gr);
}

.bs {
  background: var(--rdb);
  color: var(--rd);
}

.bp {
  background: var(--amb);
  color: var(--am);
}

.lc-info {
  padding: 12px 13px;
}

.lc-t {
  font-size: 13px;
  font-weight: 700;
  margin-bottom: 3px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.lc-p {
  font-size: 13px;
  font-weight: 700;
  color: var(--br);
}

.lc-m {
  font-size: 11px;
  color: var(--tx3);
  margin-top: 2px;
}

.lc-f {
  display: flex;
  gap: 6px;
  padding: 0 12px 12px;
}

.lf {
  flex: 1;
  padding: 7px 4px;
  border-radius: 7px;
  border: 1px solid var(--bor);
  background: var(--bg2);
  font-size: 11px;
  font-weight: 600;
  cursor: pointer;
  font-family: 'Sora', sans-serif;
  color: var(--tx);
  transition: .15s;
}

.lf:hover {
  background: var(--bg3);
}

.lf.del {
  color: var(--rd);
  border-color: #F0C0C0;
}

.lf.del:hover {
  background: var(--rdb);
}

/* ACTIVITY ROWS (sold / purchases) */
.al {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.ac {
  background: var(--wh);
  border: 1px solid var(--bor);
  border-radius: 13px;
  padding: 15px 17px;
  display: flex;
  align-items: center;
  gap: 15px;
  transition: .18s;
}

.ac:hover {
  border-color: var(--brl);
}

.ac-i {
  width: 50px;
  height: 50px;
  border-radius: 11px;
  background: var(--bg2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26px;
  flex-shrink: 0;
}

.ac-inf {
  flex: 1;
  min-width: 0;
}

.ac-t {
  font-size: 14px;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.ac-m {
  font-size: 12px;
  color: var(--tx3);
  margin-top: 3px;
}

.ac-r {
  text-align: right;
  flex-shrink: 0;
}

.ac-p {
  font-size: 14px;
  font-weight: 700;
  color: var(--br);
}

.ac-tag {
  display: inline-block;
  margin-top: 4px;
  padding: 2px 9px;
  border-radius: 99px;
  font-size: 10px;
  font-weight: 700;
}

/* WISHLIST */
.wg {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 13px;
}

.wc {
  background: var(--wh);
  border: 1px solid var(--bor);
  border-radius: 13px;
  overflow: hidden;
  transition: .2s;
  cursor: pointer;
}

.wc:hover {
  transform: translateY(-3px);
  box-shadow: 0 6px 20px rgba(43, 27, 18, .09);
}

.wc-i {
  height: 105px;
  background: var(--bg2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34px;
}

.wc-b {
  padding: 11px 13px;
}

.wc-t {
  font-size: 13px;
  font-weight: 700;
}

.wc-p {
  font-size: 13px;
  font-weight: 700;
  color: var(--br);
  margin-top: 2px;
}

.wc-cat {
  font-size: 11px;
  color: var(--tx3);
  margin-top: 2px;
}

.wc-del {
  width: 100%;
  border: none;
  background: none;
  padding: 8px;
  font-size: 11px;
  font-weight: 600;
  color: var(--rd);
  cursor: pointer;
  font-family: 'Sora', sans-serif;
  border-top: 1px solid var(--bor);
  transition: .15s;
}

.wc-del:hover {
  background: var(--rdb);
}

/* EMPTY STATE */
.empty {
  background: var(--wh);
  border: 1px solid var(--bor);
  border-radius: 14px;
  text-align: center;
  padding: 56px 24px;
}

.ei {
  font-size: 48px;
  margin-bottom: 14px;
}

.empty h4 {
  font-family: 'Lora', serif;
  font-size: 18px;
  font-weight: 700;
  margin-bottom: 7px;
}

.empty p {
  font-size: 13px;
  color: var(--tx3);
  margin-bottom: 20px;
  line-height: 1.6;
}

.empty a {
  display: inline-block;
  background: var(--br);
  color: var(--wh);
  padding: 10px 24px;
  border-radius: 9px;
  font-size: 13px;
  font-weight: 700;
  text-decoration: none;
}

.empty a:hover {
  background: var(--brd);
}

/* EDIT MODAL */
.ov {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(15, 8, 3, .5);
  backdrop-filter: blur(3px);
  z-index: 400;
  align-items: center;
  justify-content: center;
  padding: 20px;
}

.ov.on {
  display: flex;
}

.mod {
  background: var(--wh);
  border-radius: 18px;
  width: 100%;
  max-width: 480px;
  box-shadow: 0 30px 80px rgba(0, 0, 0, .25);
  overflow: hidden;
  animation: modIn .25s cubic-bezier(.34, 1.4, .64, 1);
}

@keyframes modIn {
  from {
    transform: scale(.9) translateY(16px);
    opacity: 0
  }

  to {
    transform: scale(1) translateY(0);
    opacity: 1
  }
}

.mod-hd {
  padding: 22px 24px 18px;
  border-bottom: 1px solid var(--bor);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.mod-hd h2 {
  font-family: 'Lora', serif;
  font-size: 19px;
  font-weight: 700;
}

.mod-x {
  background: none;
  border: none;
  font-size: 24px;
  cursor: pointer;
  color: var(--tx3);
  line-height: 1;
}

.mod-sc {
  padding: 22px 24px;
  max-height: 62vh;
  overflow-y: auto;
}

.fg {
  margin-bottom: 15px;
}

.fg label {
  display: block;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .5px;
  color: var(--tx3);
  margin-bottom: 6px;
}

.fg input,
.fg textarea {
  width: 100%;
  padding: 10px 13px;
  border: 1px solid var(--bor);
  border-radius: 9px;
  font-size: 13px;
  font-family: 'Sora', sans-serif;
  background: var(--bg);
  outline: none;
  color: var(--tx);
  resize: vertical;
}

.fg input:focus,
.fg textarea:focus {
  border-color: var(--brl);
}

.mod-ft {
  padding: 16px 24px;
  border-top: 1px solid var(--bor);
  display: flex;
  gap: 10px;
  justify-content: flex-end;
}

/* TOAST */
.toast {
  position: fixed;
  bottom: 26px;
  left: 50%;
  transform: translateX(-50%) translateY(60px);
  background: var(--tx);
  color: var(--wh);
  padding: 11px 24px;
  border-radius: 99px;
  font-size: 13px;
  font-weight: 600;
  opacity: 0;
  transition: .3s ease;
  z-index: 999;
  white-space: nowrap;
  box-shadow: 0 6px 20px rgba(0, 0, 0, .25);
}

.toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

/* ANIMATIONS */
@keyframes rise {
  from {
    opacity: 0;
    transform: translateY(16px)
  }

  to {
    opacity: 1;
    transform: translateY(0)
  }
}

.r1 {
  animation: rise .4s .04s ease both;
}

.r2 {
  animation: rise .4s .12s ease both;
}

.r3 {
  animation: rise .4s .20s ease both;
}

.r4 {
  animation: rise .4s .28s ease both;
}

/* RESPONSIVE */
@media(max-width:700px) {

  .nav,
  .ph-wrap,
  .pg {
    padding-left: 16px;
    padding-right: 16px;
  }

  .pg {
    grid-template-columns: 1fr;
  }

  .lg,
  .wg {
    grid-template-columns: 1fr;
  }

  .av-float {
    margin-top: -44px;
  }

  .av {
    width: 88px;
    height: 88px;
  }

  .av-l {
    font-size: 28px;
  }

  .user-name {
    font-size: 21px;
  }
}

/* ═══════════════════════════════════════════
   RESPONSIVE ENHANCEMENTS — myprofile.css
═══════════════════════════════════════════ */
