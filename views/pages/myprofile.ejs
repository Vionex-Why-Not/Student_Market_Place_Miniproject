  .nav {
    padding: 0 16px;
    height: 54px;
  }

  .nav-logo b {
    font-size: 16px;
  }

  .nav-r {
    gap: 6px;
  }

  .btn {
    padding: 7px 12px;
    font-size: 11px;
  }

  .ph-wrap {
    padding: 0 16px;
  }

  .band {
    height: 140px;
  }

  .av-float {
    margin-top: -44px;
    margin-bottom: 12px;
  }

  .av {
    width: 88px;
    height: 88px;
  }

  .av-l {
    font-size: 30px;
  }

  .user-name {
    font-size: 22px;
  }

  .ph-name-row {
    gap: 10px;
    padding-bottom: 18px;
  }

  .ph-actions {
    gap: 6px;
  }

  .pg {
    grid-template-columns: 1fr;
    padding: 0 16px;
    gap: 16px;
    margin-bottom: 48px;
  }

  .lg,
  .wg {
    grid-template-columns: 1fr 1fr;
  }

  .tabs {
    gap: 2px;
    padding: 3px;
    margin-bottom: 16px;
  }

  .tb-btn {
    font-size: 11px;
    padding: 8px 8px;
  }

  .lc-i {
    height: 100px;
    font-size: 32px;
  }

  .lc-t {
    font-size: 12px;
  }

  .lc-p {
    font-size: 12px;
  }

  .lf {
    font-size: 10px;
    padding: 6px 4px;
  }

  .ac {
    padding: 12px 14px;
    gap: 12px;
  }

  .ac-i {
    width: 44px;
    height: 44px;
    font-size: 22px;
  }

  .ac-t {
    font-size: 13px;
  }

  .ac-p {
    font-size: 13px;
  }

  .card {
    margin-bottom: 12px;
  }

  .ch {
    padding: 12px 14px;
  }

  .cb {
    padding: 14px 14px;
  }

  .ar {
    gap: 9px;
    margin-bottom: 11px;
  }

  .ar-v {
    font-size: 12px;
  }

  .mod {
    max-width: calc(100vw - 24px);
  }

  .mod-sc {
    max-height: 55vh;
  }
}

@media (max-width: 540px) {
  .nav-r .btn:first-child {
    display: none;
  }

  /* hide Marketplace btn */
  .pills {
    gap: 5px;
  }

  .pill {
    font-size: 10px;
    padding: 3px 9px;
  }

  .lg,
  .wg {
    grid-template-columns: 1fr;
  }

  .user-name {
    font-size: 19px;
  }

  .ph-actions .btn:first-child {
    display: none;
  }

  /* hide Share on very small */
  .tabs {
    overflow-x: auto;
  }

  .tb-btn {
    min-width: auto;
    padding: 7px 10px;
  }
}

/* Mobile nav overflow fix */
@media (max-width: 540px) {
  .nav {
    gap: 6px;
    padding: 0 12px;
  }

  .nav-r {
    gap: 5px;
    overflow-x: auto;
    flex-shrink: 0;
  }

  .nav-r .btn {
    white-space: nowrap;
    min-height: 36px;
  }

  /* Ensure tap targets ≥44px */
  .tb-btn {
    min-height: 40px;
  }

  .lf,
  .wc-del {
    min-height: 36px;
  }

  /* Profile grid single col */
  .lg {
    grid-template-columns: 1fr !important;
  }
}
</style>

