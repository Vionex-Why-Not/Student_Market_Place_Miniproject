        <div class="modal-body" style="padding-top:0">
          <div class="cm-tabs">
            <button class="cm-tab on" onclick="cmTab('about',this)">About</button>
            <button class="cm-tab" onclick="cmTab('announcements',this)">Announcements</button>
            <button class="cm-tab" onclick="cmTab('events',this)">Events</button>
            <button class="cm-tab" id="cmChatTab" onclick="cmTab('chat',this)" style="display:none">🔒 Group
              Chat</button>
            <button class="cm-tab" id="cmMembTab" onclick="cmTab('members',this)" style="display:none">Members</button>
          </div>
          <div class="cm-panel on" id="cmp-about">
            <div class="cm-stats">
              <div class="cm-stat"><span id="cmMembers">—</span><small>Members</small></div>
              <div class="cm-stat"><span id="cmEvents">—</span><small>Events</small></div>
              <div class="cm-stat"><span id="cmPosts">—</span><small>Posts</small></div>
            </div>
            <p id="cmDesc" style="font-size:14px;line-height:1.7;color:var(--tx2);margin-bottom:16px"></p>
            <div id="cmJoinArea"></div>
          </div>
          <div class="cm-panel" id="cmp-announcements">
            <div id="cmAnnList"></div>
          </div>
          <div class="cm-panel" id="cmp-events">
            <div id="cmEvList"></div>
          </div>
          <div class="cm-panel" id="cmp-chat">
            <div class="chat-box" id="cmChatBox"></div>
            <div class="chat-row">
              <input id="cmChatInput" placeholder="Message the group…"
                onkeydown="if(event.key==='Enter')sendGroupMsg()">
              <button class="btn btn-p btn-sm" onclick="sendGroupMsg()">Send ➤</button>
            </div>
          </div>
          <div class="cm-panel" id="cmp-members">
            <div id="cmMemberList"></div>
            <div id="cmPendingSection"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Event Detail -->
    <div class="modal-ov" id="evModal">
      <div class="modal">
        <div class="modal-hd">
          <h3 id="evmTitle"></h3><button class="mod-x" onclick="closeModal('evModal')">×</button>
        </div>
        <div class="modal-body">
          <div class="ev-detail-row"><span>📅</span><span id="evmDate"></span></div>
          <div class="ev-detail-row"><span>📍</span><span id="evmVenue"></span></div>
          <div class="ev-detail-row"><span>🏛️</span><span id="evmComm"></span></div>
          <div class="ev-detail-row"><span>👥</span><span id="evmCount"></span></div>
          <p id="evmDesc" style="margin:14px 0;font-size:13px;line-height:1.75;color:var(--tx2)"></p>
          <div id="evmRsvpArea"></div>
          <div id="evmAdminArea"></div>
        </div>
      </div>
    </div>

    <!-- Admin Requests -->
    <div class="modal-ov" id="adminReqModal">
      <div class="modal modal-wide">
        <div class="modal-hd">
          <h3>Manage Join Requests</h3><button class="mod-x" onclick="closeModal('adminReqModal')">×</button>
        </div>
        <div class="modal-body">
          <div id="adminReqList"></div>
        </div>
      </div>
    </div>

    <!-- Confirm Delete -->
    <div class="modal-ov" id="confirmModal">
      <div class="modal confirm-modal">
        <div class="modal-hd">
          <h3>Confirm Delete</h3><button class="mod-x" onclick="closeModal('confirmModal')">×</button>
        </div>
        <div class="confirm-body" id="confirmText"></div>
        <div class="modal-ft" style="margin-top:16px">
          <button class="btn btn-g" onclick="closeModal('confirmModal')">Cancel</button>
          <button class="btn btn-out" id="confirmOkBtn">Delete</button>
        </div>
      </div>
    </div>

    <div class="toast" id="toast"></div>
  </div>

<script>

// ── Auth check ────────────────────────────────────────────────────────────────
const user = JSON.parse(localStorage.getItem("user"));
if (!user) { alert("Please login first"); location.href = "/login"; }

let userIsAdmin = !!(user && user.isAdmin);
let allComms    = [];
let allEvents   = [];
let activeCmId  = null;

// ── Helpers ───────────────────────────────────────────────────────────────────
const $ = id => document.getElementById(id);
function toast(msg) {
  const t = $("toast"); t.textContent = msg; t.classList.add("show");
  setTimeout(() => t.classList.remove("show"), 2500);
}
function timeAgo(iso) {
  const d = (Date.now() - new Date(iso)) / 1000;
  if (d < 60) return "just now"; if (d < 3600) return Math.floor(d/60) + "m ago";
  if (d < 86400) return Math.floor(d/3600) + "h ago"; return Math.floor(d/86400) + "d ago";
}
function fmtDate(iso) {
  const d = new Date(iso);
  return d.toLocaleDateString("en-IN",{weekday:"short",day:"numeric",month:"short",year:"numeric"}) + " at " + d.toLocaleTimeString("en-IN",{hour:"2-digit",minute:"2-digit"});
}
function openModal(id)  { $(id).classList.add("open"); }
function closeModal(id) { $(id).classList.remove("open"); }
document.querySelectorAll(".modal-ov").forEach(ov => ov.addEventListener("click", e => { if(e.target===ov) ov.classList.remove("open"); }));

function confirmDelete(text, onOk) {
  $("confirmText").textContent = text;
  const btn = $("confirmOkBtn");
  btn.onclick = () => { closeModal("confirmModal"); onOk(); };
  openModal("confirmModal");
}

// ── Init ──────────────────────────────────────────────────────────────────────
function setupUI() {
  // Nav user label
  $("navUser").textContent = "Hi, " + user.name.split(" ")[0] + (userIsAdmin ? " ⚙️" : " 🎓");

  // Switch button text
  if (userIsAdmin) {
    $("switchBtn").textContent = "↩ Switch to Student";
    $("adminBar").style.display = "flex";
    $("adminNameBadge").textContent = "Admin: " + user.name;
    // Load pending count for badge
    loadPendingCount();
  } else {
    $("switchBtn").textContent = "↩ Switch to Admin";
    $("adminBar").style.display = "none";
  }
}

function switchRole() {
  if (userIsAdmin) {
    // Already admin, switch back to student mode
    // Remove isAdmin flag and re-save
    const studentUser = { ...user };
    delete studentUser.isAdmin;
    // Actually log out admin and go to student login
    localStorage.removeItem("user");
    location.href = "/login";
  } else {
    // Go to admin login
    location.href = "/admin";
  }
}

function signOut() { localStorage.removeItem("user"); location.href = "/login"; }

async function loadPendingCount() {
  try {
    const r = await fetch(`/committee-requests/pending`);
    const rows = await r.json();
    const badge = $("reqCountBadge");
    if (rows.length > 0) { badge.textContent = rows.length; badge.style.display = "inline"; }
    else badge.style.display = "none";
  } catch {}
}

// ── Stats ─────────────────────────────────────────────────────────────────────
async function loadStats() {
  try {
    const [cr, er] = await Promise.all([fetch(`/committees`), fetch(`/committee-events`)]);
    const comms = await cr.json(); const events = await er.json();
    animNum("hComm", comms.length); animNum("hEv", events.length);
  } catch {}
}
function animNum(id, target) {
  let n = 0; const s = Math.ceil(target / 30);
  const t = setInterval(() => { n = Math.min(n+s, target); $(id).textContent = n; if(n>=target)clearInterval(t); }, 40);
}

// ── Views ─────────────────────────────────────────────────────────────────────
function goView(id, el) {
  document.querySelectorAll(".view").forEach(v => v.classList.remove("on"));
  document.querySelectorAll(".sb-btn").forEach(b => b.classList.remove("on"));
  $("view-"+id).classList.add("on"); el.classList.add("on");
  if(id==="feed")          loadFeed();
  if(id==="committees")    loadComms();
  if(id==="events")        loadEvents();
  if(id==="mygroups")      loadMyGroups();
  if(id==="notifications") loadNotifications();
}

// ── Side committee list ───────────────────────────────────────────────────────
async function loadSideComms() {
  try {
    const r = await fetch(`/my-committees/${getUserId(user)}`);
    const data = await r.json();
    const el = $("sideCommList");
    if (!data.length) { el.innerHTML = `<div class="sb-empty">No memberships yet</div>`; return; }
    el.innerHTML = data.map(c => `<div class="sb-comm-item" onclick="openCommittee('${c._id||c.id}')">${c.icon} ${c.name}</div>`).join("");
  } catch {}
}

// ── FEED ──────────────────────────────────────────────────────────────────────
async function loadFeed() {
  const el = $("feedContainer");
  try {
    const [ar, er] = await Promise.all([fetch(`/announcements`), fetch(`/committee-events`)]);
    const anns = await ar.json(); const events = await er.json();
    let items = [
      ...anns.map(a => ({...a, _type:"ann", _time:a.created_at})),
      ...events.map(e => ({...e, _type:"ev", _time:e.event_date}))
    ].sort((a,b) => new Date(b._time) - new Date(a._time));

    if (!items.length) { el.innerHTML = `<div class="empty"><div class="ei">📰</div><h4>No activity yet</h4><p>Posts from committees will appear here.</p></div>`; return; }
    el.innerHTML = items.map(item => {
      if (item._type === "ann") {
        const bc = item.type==="important"?"fb-important":item.type==="event"?"fb-event":"fb-info";
        const delBtn = userIsAdmin ? `<button class="feed-del" onclick="event.stopPropagation();deleteAnnouncement(${item.id})">🗑 Delete</button>` : "";
        return `<div class="feed-card">
          ${delBtn}
          <div class="feed-icon">${item.committee_icon||"🏛️"}</div>
          <div class="feed-body">
            <div class="feed-meta">📢 ${item.committee_name} · ${timeAgo(item.created_at)}</div>
            <div class="feed-title">${item.title}</div>
            <div class="feed-text">${item.body}</div>
            <span class="feed-badge ${bc}">${item.type==="important"?"⚠️ Important":item.type==="event"?"📅 Event":"ℹ️ Info"}</span>
          </div></div>`;
      } else {
        const delBtn = userIsAdmin ? `<button class="feed-del" onclick="event.stopPropagation();deleteEvent(${item.id})">🗑 Delete</button>` : "";
        return `<div class="feed-card clickable" onclick="openEvent('${item._id||item.id}')">
          ${delBtn}
          <div class="feed-icon">${item.committee_icon||"📅"}</div>
          <div class="feed-body">
            <div class="feed-meta">📅 ${item.committee_name} · ${fmtDate(item.event_date)}</div>
            <div class="feed-title">${item.title}</div>
            <div class="feed-text">${item.description}</div>
            <div class="feed-text" style="margin-top:4px;font-size:12px">📍 ${item.venue||"TBA"}</div>
            <span class="feed-badge fb-announcement">🎉 Event</span>
          </div></div>`;
      }
    }).join("");
  } catch { el.innerHTML = `<div class="empty"><div class="ei">⚠️</div><h4>Could not load feed</h4><p>Make sure the server is running.</p></div>`; }
}

// ── COMMITTEES ────────────────────────────────────────────────────────────────
async function loadComms() {
  try {
    const r = await fetch(`/committees`);
    allComms = await r.json();
    filterComms();
  } catch {}
}

function filterComms() {
  const q = ($("commSearch")?.value || "").toLowerCase();
  const cat = $("catFilter")?.value || "";
  const f = allComms.filter(c => (!q || c.name.toLowerCase().includes(q) || (c.description||"").toLowerCase().includes(q)) && (!cat || c.category===cat));
  renderCommGrid(f);
}

function renderCommGrid(comms) {
  const el = $("commGrid");
  if (!comms.length) { el.innerHTML = `<div class="empty" style="grid-column:1/-1"><div class="ei">🔍</div><h4>No results</h4></div>`; return; }
  el.innerHTML = comms.map((c, i) => {
    const delBtn = userIsAdmin ? `<button class="admin-del" onclick="event.stopPropagation();deleteCommittee(${c.id},'${c.name}')">🗑</button>` : "";
    return `<div class="comm-card" style="animation-delay:${i*0.04}s">
      <div class="comm-banner">${c.icon||"🏛️"}${delBtn}</div>
      <div class="comm-body">
        <div class="comm-name">${c.name}</div>
        <div class="comm-cat">${c.category}</div>
        <div class="comm-desc">${c.description||""}</div>
      </div>
      <div class="comm-footer">
        <span class="comm-members">👥 ${c.member_count||0} members</span>
        <button class="btn btn-g btn-sm" onclick="openCommittee('${c._id||c.id}')">View →</button>
      </div>
    </div>`;
  }).join("");
}

// ── EVENTS ────────────────────────────────────────────────────────────────────
async function loadEvents() {
  try {
    const r = await fetch(`/committee-events`);
    allEvents = await r.json();
    renderEventGrid(allEvents);
  } catch {}
}

function renderEventGrid(events) {
  const el = $("evGrid");
  if (!events.length) { el.innerHTML = `<div class="empty" style="grid-column:1/-1"><div class="ei">📅</div><h4>No events yet</h4></div>`; return; }
  el.innerHTML = events.map((e, i) => {
    const d = new Date(e.event_date);
    const pct = e.max_participants ? Math.round(((e.registered_count||0)/e.max_participants)*100) : 0;
    const delBtn = userIsAdmin ? `<button class="ev-admin-del" onclick="event.stopPropagation();deleteEvent(${e.id})">🗑 Delete</button>` : "";
    return `<div class="ev-card" style="animation-delay:${i*0.04}s" onclick="openEvent('${e._id||e.id}')">
      ${delBtn}
      <div class="ev-top">
        <div class="ev-date-chip">📅 ${d.toLocaleDateString("en-IN",{day:"numeric",month:"short",year:"numeric"})}</div>
        <div class="ev-card-title">${e.title}</div>
        <div class="ev-card-comm">${e.committee_icon||"🏛️"} ${e.committee_name}</div>
      </div>
      <div class="ev-body2">
        <div class="ev-row"><span>📍</span><span>${e.venue||"TBA"}</span></div>
        <div class="ev-row"><span>🕐</span><span>${d.toLocaleTimeString("en-IN",{hour:"2-digit",minute:"2-digit"})}</span></div>
        ${e.max_participants ? `<div class="ev-prog-bar"><div class="ev-prog-fill" style="width:${Math.min(pct,100)}%"></div></div><div class="ev-prog-txt">${e.registered_count||0}/${e.max_participants} registered</div>` : `<div class="ev-row"><span>👥</span><span>${e.registered_count||0} registered</span></div>`}
      </div>
    </div>`;
  }).join("");
}

// ── EVENT DETAIL ──────────────────────────────────────────────────────────────
async function openEvent(id) {
  // Refresh events if needed
  if (!allEvents.length) { const r = await fetch(`/committee-events`); allEvents = await r.json(); }
  const e = allEvents.find(e => String(e._id||e.id) === String(id));
  if (!e) return;
  $("evmTitle").textContent = e.title;
  $("evmDate").textContent = fmtDate(e.event_date);
  $("evmVenue").textContent = e.venue || "TBA";
  $("evmComm").textContent = (e.committee_icon||"🏛️") + " " + e.committee_name;
  $("evmDesc").textContent = e.description || "";
  const cnt = e.registered_count || 0;
  $("evmCount").textContent = e.max_participants ? `${cnt}/${e.max_participants} (${Math.round(cnt/e.max_participants*100)}% full)` : `${cnt} registered`;

  const rsvpEl = $("evmRsvpArea");
  const admEl = $("evmAdminArea");
  admEl.innerHTML = "";
  if (userIsAdmin) {
    rsvpEl.innerHTML = `<div style="font-size:13px;color:var(--br);font-weight:600;padding:10px 0">⚙️ Admin view — ${cnt} registrations</div>`;
    admEl.innerHTML = `<button class="btn btn-out" style="width:100%;margin-top:8px" onclick="deleteEvent('${id}');closeModal('evModal')">🗑️ Delete This Event</button>`;
  } else {
    try {
      const rr = await fetch(`/committee-events/${id}/rsvp/${getUserId(user)}`);
      const rd = await rr.json();
      if (rd.rsvped) {
        rsvpEl.innerHTML = `<button class="btn-rsvp done" disabled>✅ You're Registered</button>`;
      } else if (e.max_participants > 0 && cnt >= e.max_participants) {
        rsvpEl.innerHTML = `<button class="btn-rsvp" disabled>Event Full</button>`;
      } else {
        rsvpEl.innerHTML = `<button class="btn-rsvp" onclick="rsvpEvent('${id}')">Register for Event →</button>`;
      }
    } catch { rsvpEl.innerHTML = `<button class="btn-rsvp" onclick="rsvpEvent('${id}')">Register for Event →</button>`; }
  }
  openModal("evModal");
}

async function rsvpEvent(id) {
  try {
    const r = await fetch(`/committee-events/${id}/rsvp`, {method:"POST",headers:{ "Authorization": "Bearer " + getToken(),"Content-Type":"application/json"},body:JSON.stringify({user_id:getUserId(user)})});
    const d = await r.json();
    if (d.success) { toast("Registered! 🎉"); closeModal("evModal"); loadEvents(); }
    else toast(d.error || "Could not register");
  } catch { toast("Server error"); }
}

// ── COMMITTEE DETAIL ──────────────────────────────────────────────────────────
async function openCommittee(id) {
  activeCmId = id;
  if (!allComms.length) { const r = await fetch(`/committees`); allComms = await r.json(); }
  const c = allComms.find(c => String(c._id||c.id) === String(id));
  if (!c) return;

  $("cmIcon").textContent = c.icon || "🏛️";
  $("cmName").textContent = c.name;
  $("cmCat").textContent  = c.category;
  $("cmDesc").textContent = c.description || "";
  $("cmMembers").textContent = c.member_count || 0;
  $("cmEvents").textContent  = c.event_count || 0;
  $("cmPosts").textContent   = c.post_count || 0;

  let myStatus = "none";
  if (!userIsAdmin) {
    try { const r = await fetch(`/committees/${id}/membership/${getUserId(user)}`); const d = await r.json(); myStatus = d.status; } catch {}
  }

  const joinEl = $("cmJoinArea");
  if (userIsAdmin) {
    joinEl.innerHTML = `<div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
      <span style="color:var(--br);font-weight:700;font-size:14px">⚙️ Managing as Admin</span>
      <button class="btn btn-out btn-sm" onclick="deleteCommittee('${id}','${c.name}')">🗑️ Delete Committee</button>
    </div>`;
  }
  else if (myStatus==="approved") joinEl.innerHTML = `<span style="color:var(--gr);font-weight:700;font-size:14px">✅ You are a member</span>`;
  else if (myStatus==="pending")  joinEl.innerHTML = `<span style="color:var(--am);font-weight:700;font-size:14px">⏳ Join request pending</span>`;
  else if (myStatus==="rejected") joinEl.innerHTML = `<span style="color:var(--rd);font-weight:700;font-size:14px">❌ Request was rejected</span>`;
  else joinEl.innerHTML = `<button class="btn btn-p" onclick="requestJoin('${id}')">Request to Join</button>`;

  const showPriv = myStatus==="approved" || userIsAdmin;
  $("cmChatTab").style.display = showPriv ? "inline-block" : "none";
  $("cmMembTab").style.display = showPriv ? "inline-block" : "none";

  document.querySelectorAll(".cm-tab").forEach(t => t.classList.remove("on"));
  document.querySelectorAll(".cm-panel").forEach(p => p.classList.remove("on"));
  document.querySelector(".cm-tab").classList.add("on");
  $("cmp-about").classList.add("on");
  openModal("commModal");
}

function cmTab(panel, el) {
  document.querySelectorAll(".cm-tab").forEach(t => t.classList.remove("on"));
  document.querySelectorAll(".cm-panel").forEach(p => p.classList.remove("on"));
  el.classList.add("on"); $("cmp-"+panel).classList.add("on");
  if (panel==="announcements") loadCmAnns(activeCmId);
  if (panel==="events")        loadCmEvents(activeCmId);
  if (panel==="chat")          loadGroupChat(activeCmId);
  if (panel==="members")       loadMembers(activeCmId);
}

async function requestJoin(id) {
  try {
    const r = await fetch(`/committees/${id}/join`, {method:"POST",headers:{ "Authorization": "Bearer " + getToken(),"Content-Type":"application/json"},body:JSON.stringify({user_id:getUserId(user)})});
    const d = await r.json();
    if (d.success) { toast("Join request sent! ⏳"); openCommittee(id); loadSideComms(); }
    else toast(d.error || "Could not send request");
  } catch { toast("Server error"); }
}

async function loadCmAnns(id) {
  try {
    const r = await fetch(`/announcements`);
    const all = await r.json();
    const anns = all.filter(a => String(a.committee_id||a.committee?._id) === String(id));
    const el = $("cmAnnList");
    if (!anns.length) { el.innerHTML = `<div class="empty"><div class="ei">📢</div><h4>No announcements yet</h4></div>`; return; }
    el.innerHTML = anns.map(a => {
      const delBtn = userIsAdmin ? `<button class="ann-del" onclick="deleteAnnouncement('${a._id||a.id}')">🗑</button>` : "";
      return `<div class="ann-item">
        ${delBtn}
        <span class="ann-badge ${a.type}">${a.type==="important"?"⚠️ Important":a.type==="event"?"📅 Event":"ℹ️ Info"}</span>
        <div class="ann-title">${a.title}</div>
        <div class="ann-body">${a.body}</div>
        <div class="ann-time">Posted ${timeAgo(a.created_at)}</div>
      </div>`;
    }).join("");
  } catch {}
}

async function loadCmEvents(id) {
  try {
    const r = await fetch(`/committee-events`);
    const all = await r.json();
    const evs = all.filter(e => String(e.committee_id||e.committee?._id) === String(id));
    const el = $("cmEvList");
    if (!evs.length) { el.innerHTML = `<div class="empty"><div class="ei">📅</div><h4>No events yet</h4></div>`; return; }
    el.innerHTML = evs.map(e => `<div style="background:var(--bg2);border:1px solid var(--bor);border-radius:12px;padding:14px;margin-bottom:10px;cursor:pointer" onclick="closeModal('commModal');openEvent('${e._id||e.id}')">
      <div style="font-weight:700;font-size:15px;margin-bottom:4px">${e.title}</div>
      <div style="font-size:12px;color:var(--tx3)">📅 ${fmtDate(e.event_date)} · 📍 ${e.venue||"TBA"}</div>
    </div>`).join("");
  } catch {}
}

async function loadGroupChat(id) {
  try {
    const r = await fetch(`/committees/${id}/messages`);
    const msgs = await r.json();
    const el = $("cmChatBox");
    if (!msgs.length) { el.innerHTML = `<div style="text-align:center;color:var(--tx3);font-size:13px;padding:40px">No messages yet. Say hello! 👋</div>`; return; }
    el.innerHTML = msgs.map(m => {
      const mine = m.sender_id === getUserId(user);
      return `<div class="msg ${mine?"mine":"theirs"}">
        ${!mine ? `<div class="msg-sender">${m.sender_name}</div>` : ""}
        ${m.message}
        <div class="msg-time">${timeAgo(m.sent_at)}</div>
      </div>`;
    }).join("");
    el.scrollTop = el.scrollHeight;
  } catch {}
}

async function sendGroupMsg() {
  const input = $("cmChatInput");
  const text = input.value.trim();
  if (!text || !activeCmId) return;
  input.value = "";
  try {
    await fetch(`/committees/${activeCmId}/messages`, {method:"POST",headers:{ "Authorization": "Bearer " + getToken(),"Content-Type":"application/json"},body:JSON.stringify({sender_id:getUserId(user),message:text})});
    loadGroupChat(activeCmId);
  } catch { toast("Could not send message"); }
}

// ── MY GROUPS ─────────────────────────────────────────────────────────────────
async function loadMyGroups() {
  const el = $("myGroupsCont");
  try {
    const r = await fetch(`/my-committees/${getUserId(user)}`);
    const comms = await r.json();
    if (!comms.length) { el.innerHTML = `<div class="empty"><div class="ei">🔒</div><h4>No private groups yet</h4><p>Join a committee to access its group chat.</p></div>`; return; }
    el.innerHTML = comms.map(c => `<div class="group-card">
      <div class="group-hd">
        <div style="display:flex;align-items:center;gap:12px">
          <span style="font-size:28px">${c.icon||"🏛️"}</span>
          <div><h4 style="font-size:15px;font-weight:800">${c.name}</h4><small style="color:var(--tx3)">${c.category}</small></div>
        </div>
        <button class="btn btn-p btn-sm" onclick="openCommToChat('${c._id||c.id}')">Open Chat →</button>
      </div>
    </div>`).join("");
  } catch { el.innerHTML = `<div class="empty"><div class="ei">⚠️</div><h4>Could not load groups</h4></div>`; }
}

async function openCommToChat(id) {
  if (!allComms.length) { const r = await fetch(`/committees`); allComms = await r.json(); }
  openCommittee(id);
  setTimeout(() => { const t = $("cmChatTab"); if(t) t.click(); }, 200);
}

// ── MEMBERS ───────────────────────────────────────────────────────────────────
async function loadMembers(id) {
  try {
    const r = await fetch(`/committees/${id}/members`);
    const rows = await r.json();
    const approved = rows.filter(m => m.status==="approved");
    const pending  = rows.filter(m => m.status==="pending");

    let html = `<div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--tx3);margin-bottom:12px">Members (${approved.length})</div>`;
    if (!approved.length) html += `<p style="color:var(--tx3);font-size:13px">No approved members yet.</p>`;
    else html += approved.map(m => {
      const removeBtn = userIsAdmin ? `<button class="btn-reject2" style="margin-left:8px" onclick="memberAction('${id}','${m.user_id}','reject')">Remove</button>` : "";
      return `<div class="member-row">
        <div class="member-av">${(m.user_name||"?")[0].toUpperCase()}</div>
        <div style="flex:1"><div class="member-name">${m.user_name}</div><div class="member-email">${m.user_email}</div></div>
        <span class="member-badge mb-member">Member</span>${removeBtn}
      </div>`;
    }).join("");
    $("cmMemberList").innerHTML = html;

    const pEl = $("cmPendingSection");
    if (pending.length) {
      pEl.innerHTML = `<div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--tx3);margin:20px 0 12px;padding-top:14px;border-top:1px solid var(--bor)">Pending Requests (${pending.length})</div>` +
        pending.map(m => `<div class="req-row">
          <div class="member-av">${(m.user_name||"?")[0].toUpperCase()}</div>
          <div class="req-info"><div class="req-name">${m.user_name}</div><div class="req-meta">${m.user_email} · ${timeAgo(m.requested_at)}</div></div>
          <div class="req-actions">
            <button class="btn-accept" onclick="memberAction('${id}','${m.user_id}','approve')">✓ Accept</button>
            <button class="btn-reject2" onclick="memberAction('${id}','${m.user_id}','reject')">✕ Reject</button>
          </div>
        </div>`).join("");
    } else { pEl.innerHTML = userIsAdmin ? `<p style="color:var(--tx3);font-size:13px;margin-top:16px;padding-top:14px;border-top:1px solid var(--bor)">No pending requests.</p>` : ""; }
  } catch {}
}

async function memberAction(commId, userId, action) {
  try {
    const r = await fetch(`/committees/${commId}/members/${userId}/${action}`, {method:"POST", headers: { "Content-Type": "application/json", "Authorization": "Bearer " + getToken() }});
    const d = await r.json();
    if (d.success) {
      toast(action==="approve" ? "Approved ✅" : "Rejected / Removed");
      loadMembers(commId); loadSideComms(); loadPendingCount();
    } else toast("Action failed");
  } catch { toast("Server error"); }
}

// ── NOTIFICATIONS ─────────────────────────────────────────────────────────────
async function loadNotifications() {
  try {
    const r = await fetch(`/notifications/${getUserId(user)}`);
    const notifs = await r.json();
    const el = $("notifList");
    await fetch(`/notifications/read-all/${getUserId(user)}`, {method:"POST", headers: { "Content-Type": "application/json", "Authorization": "Bearer " + getToken() }});
    loadNotifBadge();
    if (!notifs.length) { el.innerHTML = `<div class="empty"><div class="ei">🔔</div><h4>No notifications</h4><p>You're all caught up!</p></div>`; return; }
    el.innerHTML = notifs.map(n => `<div class="notif-item ${n.is_read?'':'unread'}">
      <div class="notif-icon">${n.icon||"🔔"}</div>
      <div>
        <div class="notif-title">${n.title}</div>
        <div class="notif-text">${n.body||""}</div>
        <div class="notif-time">${timeAgo(n.created_at)}</div>
      </div>
    </div>`).join("");
  } catch {}
}

async function loadNotifBadge() {
  try {
    const r = await fetch(`/notifications/unread-count/${getUserId(user)}`);
    const d = await r.json();
    const badge = $("notifBadge");
    if (badge) { if(d.count>0){badge.textContent=d.count;badge.style.display="inline-flex";}else badge.style.display="none"; }
  } catch {}
}

// ── ADMIN: CREATE COMMITTEE ───────────────────────────────────────────────────
async function createCommittee() {
  const name = $("cName").value.trim(), desc = $("cDesc").value.trim(), cat = $("cCat").value, icon = $("cIcon").value.trim()||"🏛️";
  if (!name || !desc) { toast("Please fill all fields"); return; }
  try {
    const r = await fetch(`/committees`, {method:"POST",headers:{ "Authorization": "Bearer " + getToken(),"Content-Type":"application/json"},body:JSON.stringify({name,description:desc,category:cat,icon,created_by:getUserId(user)})});
    const d = await r.json();
    if (d.success) { closeModal("crtCommModal"); $("cName").value=""; $("cDesc").value=""; toast("Committee created! 🏛️"); loadComms(); loadStats(); }
    else toast(d.error || "Failed");
  } catch { toast("Server error"); }
}

// ── ADMIN: DELETE COMMITTEE ───────────────────────────────────────────────────
function deleteCommittee(id, name) {
  confirmDelete(`Delete committee "${name}"? All members, events, and announcements will be permanently removed.`, async () => {
    try {
      const r = await fetch(`/committees/${id}`, {method:"DELETE", headers: { "Content-Type": "application/json", "Authorization": "Bearer " + getToken() }});
      const d = await r.json();
      if (d.success) { toast("Committee deleted"); closeModal("commModal"); loadComms(); loadStats(); }
      else toast(d.error || "Failed to delete");
    } catch { toast("Server error"); }
  });
}

// ── ADMIN: CREATE EVENT ───────────────────────────────────────────────────────
async function openCreateEvent() {
  try { const r = await fetch(`/committees`); const c = await r.json(); $("evComm").innerHTML = c.map(c => `<option value="${c.id}">${c.icon} ${c.name}</option>`).join(""); } catch {}
  openModal("crtEvModal");
}

async function createEvent() {
  const title = $("evTitle").value.trim(), desc = $("evDesc").value.trim(), date = $("evDate").value,
        venue = $("evVenue").value.trim(), max = parseInt($("evMax").value)||0, commId = $("evComm").value;
  if (!title || !date || !venue) { toast("Please fill all fields"); return; }
  try {
    const r = await fetch(`/committee-events`, {method:"POST",headers:{ "Authorization": "Bearer " + getToken(),"Content-Type":"application/json"},body:JSON.stringify({committee_id:commId,title,description:desc,event_date:date,venue,max_participants:max,created_by:getUserId(user)})});
    const d = await r.json();
    if (d.success) { closeModal("crtEvModal"); $("evTitle").value=""; $("evDesc").value=""; $("evDate").value=""; $("evVenue").value=""; toast("Event created! 📅"); loadEvents(); loadFeed(); loadStats(); }
    else toast(d.error || "Failed");
  } catch { toast("Server error"); }
}

// ── ADMIN: DELETE EVENT ───────────────────────────────────────────────────────
function deleteEvent(id) {
  const e = allEvents.find(e => String(e._id||e.id) === String(id));
  confirmDelete(`Delete event "${e?e.title:'this event'}"? All RSVPs will be removed.`, async () => {
    try {
      const r = await fetch(`/committee-events/${id}`, {method:"DELETE", headers: { "Content-Type": "application/json", "Authorization": "Bearer " + getToken() }});
      const d = await r.json();
      if (d.success) { toast("Event deleted"); loadEvents(); loadFeed(); loadStats(); }
      else toast(d.error || "Failed to delete");
    } catch { toast("Server error"); }
  });
}

// ── ADMIN: CREATE ANNOUNCEMENT ────────────────────────────────────────────────
async function openCreateAnn() {
  try { const r = await fetch(`/committees`); const c = await r.json(); $("annComm").innerHTML = c.map(c => `<option value="${c.id}">${c.icon} ${c.name}</option>`).join(""); } catch {}
  openModal("crtAnnModal");
}

async function createAnnouncement() {
  const title = $("annTitle").value.trim(), body = $("annBody").value.trim(), type = $("annType").value, commId = $("annComm").value;
  if (!title || !body) { toast("Please fill all fields"); return; }
  try {
    const r = await fetch(`/announcements`, {method:"POST",headers:{ "Authorization": "Bearer " + getToken(),"Content-Type":"application/json"},body:JSON.stringify({committee_id:commId,title,body,type,created_by:getUserId(user)})});
    const d = await r.json();
    if (d.success) { closeModal("crtAnnModal"); $("annTitle").value=""; $("annBody").value=""; toast("Announcement posted! 📢"); loadFeed(); }
    else toast(d.error || "Failed");
  } catch { toast("Server error"); }
}

// ── ADMIN: DELETE ANNOUNCEMENT ────────────────────────────────────────────────
function deleteAnnouncement(id) {
  confirmDelete("Delete this announcement permanently?", async () => {
    try {
      const r = await fetch(`/announcements/${id}`, {method:"DELETE", headers: { "Content-Type": "application/json", "Authorization": "Bearer " + getToken() }});
      const d = await r.json();
      if (d.success) { toast("Announcement deleted"); loadFeed(); loadCmAnns(activeCmId); }
      else toast(d.error || "Failed to delete");
    } catch { toast("Server error"); }
  });
}

// ── ADMIN: VIEW ALL REQUESTS ──────────────────────────────────────────────────
async function openAdminRequests() {
  const el = $("adminReqList");
  try {
    const r = await fetch(`/committee-requests/pending`);
    const rows = await r.json();
    if (!rows.length) { el.innerHTML = `<div class="empty"><div class="ei">✅</div><h4>No pending requests</h4><p>All handled!</p></div>`; openModal("adminReqModal"); return; }
    el.innerHTML = rows.map(m => `<div class="req-row">
      <div class="member-av">${(m.user_name||"?")[0].toUpperCase()}</div>
      <div class="req-info">
        <div class="req-name">${m.user_name}</div>
        <div class="req-meta">${m.user_email} · Wants to join ${m.committee_icon} ${m.committee_name} · ${timeAgo(m.requested_at)}</div>
      </div>
      <div class="req-actions">
        <button class="btn-accept" onclick="memberAction('${m.committee_id}','${m.user_id}','approve');openAdminRequests()">✓ Accept</button>
        <button class="btn-reject2" onclick="memberAction('${m.committee_id}','${m.user_id}','reject');openAdminRequests()">✕ Reject</button>
      </div>
    </div>`).join("");
  } catch { el.innerHTML = `<div class="empty"><div class="ei">⚠️</div><h4>Could not load requests</h4></div>`; }
  openModal("adminReqModal");
}

// ── BOOT ──────────────────────────────────────────────────────────────────────
setupUI();
Promise.all([loadStats(), loadFeed(), loadSideComms()]);
loadNotifBadge();

function toggleMenu() {
  document.getElementById("navMenu").classList.toggle("active");
}
</script>

