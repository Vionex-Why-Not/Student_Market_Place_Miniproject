<%- include('../partials/head', { title, headExtras: '', extraScript: '' }) %>
<style>
*,
*::before,
*::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box
}

:root {
  --br: #7B4B2A;
  --brd: #5A361D;
  --brl: #C9A27A;
  --brp: #F0E4D6;
  --bg: #F7F3EE;
  --bg2: #EFE6DB;
  --bg3: #E5D8C8;
  --bor: #DDD0C0;
  --tx: #231209;
  --tx2: #6B4838;
  --tx3: #9C7B66;
  --wh: #FFFFFF;
  --gr: #276840;
  --grb: #E8F5ED;
  --rd: #B83232;
  --rdb: #FDEAEA;
  --am: #A06B10;
  --amb: #FEF3DC;
  --blue: #2F5FAB;
  --blueb: #EBF3FF;
}

body {
  font-family: 'Sora', sans-serif;
  background: var(--bg);
  color: var(--tx);
  min-height: 100vh;
  -webkit-font-smoothing: antialiased
}

/* ─── NAV ─── */
.nav {
  position: sticky;
  top: 0;
  z-index: 200;
  background: rgba(255, 255, 255, .95);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--bor);
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 0 28px;
  height: 62px
}

.nav-logo {
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 10px
}

.nav-logo-icon {
  width: 34px;
  height: 34px;
  border-radius: 9px;
  background: linear-gradient(135deg, var(--brl), var(--brd));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 800;
  color: #fff;
  font-family: 'Lora', serif
}

.nav-logo b {
  font-size: 17px;
  font-weight: 800;
  color: var(--br);
  display: block;
  line-height: 1.1
}

.nav-logo small {
  font-size: 10px;
  color: var(--tx3)
}

.nav-links {
  display: flex;
  gap: 4px;
  margin-left: 8px
}

.nl {
  text-decoration: none;
  padding: 7px 13px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  color: var(--tx2);
  transition: .18s
}

.nl:hover,
.nl.active {
  background: var(--bg2);
  color: var(--br)
}

.nav-r {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap
}

.nav-user {
  font-size: 13px;
  font-weight: 600;
  color: var(--tx2);
  white-space: nowrap
}

.btn {
  border: none;
  cursor: pointer;
  border-radius: 9px;
  padding: 8px 16px;
  font-size: 13px;
  font-weight: 700;
  font-family: 'Sora', sans-serif;
  transition: .18s;
  white-space: nowrap
}

.btn-g {
  background: var(--bg2);
  color: var(--tx2);
  border: 1px solid var(--bor)
}

.btn-g:hover {
  background: var(--bg3)
}

.btn-p {
  background: var(--br);
  color: #fff
}

.btn-p:hover {
  background: var(--brd)
}

.btn-out {
  background: var(--rdb);
  color: var(--rd);
  border: 1px solid #F0C0C0
}

.btn-out:hover {
  background: #FADBDB
}

.btn-sm {
  padding: 6px 13px;
  font-size: 12px
}

.switch-role-btn {
  background: var(--amb);
  color: var(--am);
  border: 1px solid #F0D890;
  padding: 6px 12px;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 700;
  font-family: 'Sora', sans-serif;
  cursor: pointer;
  transition: .18s
}

.switch-role-btn:hover {
  background: #FDE8A8
}

/* ─── HERO ─── */
.hero {
  background: linear-gradient(130deg, #D4A574 0%, var(--br) 55%, #3A1E0C 100%);
  padding: 52px 40px 48px;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  gap: 24px;
  justify-content: space-between
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 60% 80% at 10% 70%, rgba(255, 255, 255, .08), transparent 60%), radial-gradient(ellipse 40% 60% at 90% 20%, rgba(255, 255, 255, .06), transparent 50%)
}

.hero-cont {
  position: relative;
  z-index: 1
}

.hero-badge {
  display: inline-block;
  background: rgba(255, 255, 255, .15);
  border: 1px solid rgba(255, 255, 255, .25);
  color: rgba(255, 255, 255, .92);
  padding: 5px 14px;
  border-radius: 99px;
  font-size: 12px;
  font-weight: 600;
  margin-bottom: 14px
}

.hero h1 {
  font-family: 'Lora', serif;
  font-size: 40px;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10px;
  letter-spacing: -.5px
}

.hero p {
  font-size: 14px;
  color: rgba(255, 255, 255, .75);
  max-width: 460px;
  margin-bottom: 24px;
  line-height: 1.6
}

.hero-stats {
  display: flex;
  gap: 28px
}

.hs {
  display: flex;
  flex-direction: column
}

.hs-num {
  font-family: 'Lora', serif;
  font-size: 26px;
  font-weight: 700;
  color: #fff;
  line-height: 1
}

.hs-lbl {
  font-size: 10px;
  color: rgba(255, 255, 255, .65);
  font-weight: 500;
  margin-top: 3px;
  text-transform: uppercase;
  letter-spacing: .5px
}

.hero-orbs {
  position: relative;
  width: 180px;
  height: 130px;
  flex-shrink: 0
}

.orb {
  position: absolute;
  border-radius: 50%;
  opacity: .22
}

.o1 {
  width: 110px;
  height: 110px;
  background: rgba(255, 255, 255, .3);
  top: 0;
  right: 10px;
  animation: fl1 6s ease-in-out infinite
}

.o2 {
  width: 60px;
  height: 60px;
  background: rgba(255, 255, 255, .2);
  bottom: 5px;
  right: 5px;
  animation: fl2 4.5s ease-in-out infinite
}

.o3 {
  width: 40px;
  height: 40px;
  background: rgba(255, 255, 255, .15);
  top: 15px;
  right: 100px;
  animation: fl1 7s ease-in-out infinite reverse
}

@keyframes fl1 {

  0%,
  100% {
    transform: translateY(0) scale(1)
  }

  50% {
    transform: translateY(-12px) scale(1.04)
  }
}

@keyframes fl2 {

  0%,
  100% {
    transform: translateY(0)
  }

  50% {
    transform: translateY(9px)
  }
}

/* ─── ADMIN BAR ─── */
.admin-bar {
  background: var(--amb);
  border-bottom: 1px solid #F0D890;
  padding: 10px 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  font-size: 13px;
  font-weight: 700;
  color: var(--am);
  flex-wrap: wrap
}

.admin-bar-left {
  display: flex;
  align-items: center;
  gap: 10px
}

.btn-adm {
  background: var(--am);
  color: #fff;
  padding: 7px 14px;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 700;
  border: none;
  cursor: pointer;
  font-family: 'Sora', sans-serif;
  transition: .18s
}

.btn-adm:hover {
  background: #7A4E08
}

.btn-adm-out {
  background: #fff;
  color: var(--am);
  border: 1px solid #F0D890;
  padding: 7px 14px;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
  font-family: 'Sora', sans-serif;
  transition: .18s
}

.btn-adm-out:hover {
  background: var(--amb)
}

.admin-name-badge {
  background: rgba(160, 107, 16, .15);
  border: 1px solid #F0D890;
  padding: 4px 10px;
  border-radius: 6px;
  font-size: 12px
}

/* ─── LAYOUT ─── */
.hub {
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 24px;
  max-width: 1200px;
  margin: 0 auto;
  padding: 28px 28px 60px;
  align-items: start
}

/* ─── SIDEBAR ─── */
.sb {
  position: sticky;
  top: 82px;
  display: flex;
  flex-direction: column;
  gap: 12px
}

.sb-card {
  background: var(--wh);
  border: 1px solid var(--bor);
  border-radius: 14px;
  overflow: hidden;
  box-shadow: 0 2px 10px rgba(43, 27, 18, .06)
}

.sb-hd {
  padding: 11px 15px;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .7px;
  color: var(--tx3);
  border-bottom: 1px solid var(--bor);
  background: var(--bg2)
}

.sb-btn {
  width: 100%;
  text-align: left;
  background: none;
  border: none;
  padding: 11px 15px;
  font-size: 13px;
  font-weight: 600;
  color: var(--tx2);
  cursor: pointer;
  font-family: 'Sora', sans-serif;
  display: flex;
  align-items: center;
  gap: 9px;
  transition: .15s;
  position: relative
}

.sb-btn:hover {
  background: var(--bg2);
  color: var(--br)
}

.sb-btn.on {
  background: var(--brp);
  color: var(--br);
  font-weight: 700
}

.sb-btn:not(:last-child) {
  border-bottom: 1px solid var(--bg2)
}

.nb {
  background: var(--rd);
  color: #fff;
  font-size: 10px;
  font-weight: 800;
  min-width: 18px;
  height: 18px;
  border-radius: 99px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 5px;
  margin-left: auto
}

.sb-comm-item {
  padding: 10px 15px;
  font-size: 12px;
  font-weight: 600;
  color: var(--br);
  cursor: pointer;
  transition: .15px;
  border-bottom: 1px solid var(--bg2)
}

.sb-comm-item:hover {
  background: var(--brp)
}

.sb-comm-item:last-child {
  border-bottom: none
}

.sb-empty {
  padding: 14px 15px;
  font-size: 12px;
  color: var(--tx3)
}

/* ─── MAIN ─── */
.view {
  display: none
}

.view.on {
  display: block
}

.view-hd {
  margin-bottom: 22px
}

.view-hd h2 {
  font-family: 'Lora', serif;
  font-size: 24px;
  font-weight: 700;
  color: var(--br);
  margin-bottom: 4px
}

.view-hd p {
  font-size: 13px;
  color: var(--tx3)
}

/* ─── SEARCH BAR ─── */
.search-bar {
  display: flex;
  gap: 10px;
  margin-bottom: 20px;
  flex-wrap: wrap
}

.sb-input {
  flex: 1;
  min-width: 180px;
  display: flex;
  align-items: center;
  gap: 9px;
  background: var(--wh);
  border: 1.5px solid var(--bor);
  border-radius: 10px;
  padding: 9px 13px;
  transition: .18s
}

.sb-input:focus-within {
  border-color: var(--brl)
}

.sb-input input {
  border: none;
  background: none;
  outline: none;
  font-family: 'Sora', sans-serif;
  font-size: 13px;
  flex: 1;
  color: var(--tx)
}

.search-bar select {
  padding: 9px 13px;
  border: 1.5px solid var(--bor);
  border-radius: 10px;
  font-size: 12px;
  font-family: 'Sora', sans-serif;
  background: var(--wh);
  color: var(--tx2);
  outline: none;
  cursor: pointer
}

/* ─── COMMITTEE GRID ─── */
.comm-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
  gap: 18px
}

.comm-card {
  background: var(--wh);
  border: 1.5px solid var(--bor);
  border-radius: 16px;
  overflow: hidden;
  transition: .22s cubic-bezier(.34, 1.2, .64, 1);
  animation: rise .35s ease both
}

@keyframes rise {
  from {
    opacity: 0;
    transform: translateY(14px)
  }

  to {
    opacity: 1;
    transform: none
  }
}

.comm-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 18px 44px rgba(123, 75, 42, .14);
  border-color: var(--brl)
}

.comm-banner {
  height: 90px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44px;
  background: linear-gradient(135deg, var(--brp), var(--bg3));
  position: relative
}

.comm-banner .admin-del {
  position: absolute;
  top: 8px;
  right: 8px;
  background: var(--rdb);
  color: var(--rd);
  border: 1px solid #F0C0C0;
  border-radius: 6px;
  padding: 3px 8px;
  font-size: 11px;
  font-weight: 700;
  cursor: pointer;
  font-family: 'Sora', sans-serif;
  display: none
}

.comm-card:hover .admin-del {
  display: block
}

.comm-body {
  padding: 16px 18px 12px
}

.comm-name {
  font-size: 15px;
  font-weight: 800;
  margin-bottom: 4px
}

.comm-cat {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .5px;
  color: var(--tx3);
  margin-bottom: 9px
}

.comm-desc {
  font-size: 12px;
  color: var(--tx2);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 14px
}

.comm-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 18px;
  border-top: 1px solid var(--bg2);
  background: var(--bg2)
}

.comm-members {
  font-size: 12px;
  color: var(--tx3);
  font-weight: 600
}

.btn-join {
  padding: 7px 14px;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 700;
  border: 1.5px solid var(--br);
  background: var(--br);
  color: #fff;
  cursor: pointer;
  font-family: 'Sora', sans-serif;
  transition: .18s
}

.btn-join:hover {
  background: var(--brd)
}

.btn-join.approved {
  background: var(--grb);
  color: var(--gr);
  border-color: #C0DEC8;
  cursor: default
}

.btn-join.pending {
  background: var(--amb);
  color: var(--am);
  border-color: #F0D890;
  cursor: default
}

/* ─── EVENTS GRID ─── */
.ev-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 18px
}

.ev-card {
  background: var(--wh);
  border: 1.5px solid var(--bor);
  border-radius: 16px;
  overflow: hidden;
  cursor: pointer;
  transition: .22s;
  animation: rise .35s ease both;
  position: relative
}

.ev-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 14px 36px rgba(123, 75, 42, .13);
  border-color: var(--brl)
}

.ev-top {
  background: linear-gradient(135deg, var(--br), var(--brd));
  padding: 20px 18px 16px;
  color: #fff
}

.ev-date-chip {
  display: inline-block;
  background: rgba(255, 255, 255, .2);
  padding: 4px 12px;
  border-radius: 99px;
  font-size: 11px;
  font-weight: 700;
  margin-bottom: 10px
}

.ev-card-title {
  font-size: 16px;
  font-weight: 800;
  margin-bottom: 4px
}

.ev-card-comm {
  font-size: 12px;
  opacity: .8
}

.ev-body2 {
  padding: 14px 18px 16px
}

.ev-row {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  font-size: 12px;
  color: var(--tx2);
  margin-bottom: 6px;
  line-height: 1.4
}

.ev-prog-bar {
  height: 6px;
  background: var(--bg3);
  border-radius: 99px;
  overflow: hidden;
  margin: 10px 0 4px
}

.ev-prog-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--br), var(--brl));
  border-radius: 99px;
  transition: .4s
}

.ev-prog-txt {
  font-size: 11px;
  color: var(--tx3);
  font-weight: 600
}

.ev-admin-del {
  position: absolute;
  top: 10px;
  right: 10px;
  background: rgba(184, 50, 50, .85);
  color: #fff;
  border: none;
  border-radius: 6px;
  padding: 4px 9px;
  font-size: 11px;
  font-weight: 700;
  cursor: pointer;
  font-family: 'Sora', sans-serif;
  display: none
}

.ev-card:hover .ev-admin-del {
  display: block
}

/* ─── FEED ─── */
.feed-list {
  display: flex;
  flex-direction: column;
  gap: 14px
}

.feed-card {
  background: var(--wh);
  border: 1.5px solid var(--bor);
  border-radius: 14px;
  padding: 18px;
  display: flex;
  gap: 14px;
  transition: .18s;
  animation: rise .3s ease both;
  position: relative
}

.feed-card:hover {
  border-color: var(--brl);
  box-shadow: 0 6px 20px rgba(123, 75, 42, .1)
}

.feed-card.clickable {
  cursor: pointer
}

.feed-icon {
  font-size: 32px;
  flex-shrink: 0;
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--brp);
  border-radius: 12px
}

.feed-body {
  flex: 1;
  min-width: 0
}

.feed-meta {
  font-size: 11px;
  color: var(--tx3);
  font-weight: 600;
  margin-bottom: 5px
}

.feed-title {
  font-size: 15px;
  font-weight: 800;
  margin-bottom: 5px;
  color: var(--tx)
}

.feed-text {
  font-size: 13px;
  color: var(--tx2);
  line-height: 1.6
}

.feed-badge {
  display: inline-block;
  font-size: 10px;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 99px;
  margin-top: 8px
}

.fb-info {
  background: var(--grb);
  color: var(--gr)
}

.fb-important {
  background: var(--amb);
  color: var(--am)
}

.fb-event {
  background: var(--blueb);
  color: var(--blue)
}

.fb-announcement {
  background: var(--brp);
  color: var(--br)
}

.feed-del {
  position: absolute;
  top: 12px;
  right: 12px;
  background: var(--rdb);
  color: var(--rd);
  border: 1px solid #F0C0C0;
  border-radius: 6px;
  padding: 3px 9px;
  font-size: 11px;
  font-weight: 700;
  cursor: pointer;
  font-family: 'Sora', sans-serif;
  display: none
}

.feed-card:hover .feed-del {
  display: block
}

/* ─── GROUPS ─── */
.group-card {
  background: var(--wh);
  border: 1.5px solid var(--bor);
  border-radius: 14px;
  overflow: hidden;
  margin-bottom: 14px;
  transition: .18s
}

.group-card:hover {
  border-color: var(--brl)
}

.group-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 18px;
  gap: 12px
}

/* ─── NOTIF ─── */
.notif-item {
  background: var(--wh);
  border: 1.5px solid var(--bor);
  border-radius: 12px;
  padding: 14px 16px;
  display: flex;
  gap: 12px;
  margin-bottom: 10px;
  transition: .18s
}

.notif-item.unread {
  border-color: var(--brl);
  background: #FDFAF6
}

.notif-icon {
  font-size: 24px;
  flex-shrink: 0
}

.notif-title {
  font-size: 14px;
  font-weight: 700;
  margin-bottom: 3px
}

.notif-text {
  font-size: 12px;
  color: var(--tx2);
  line-height: 1.5
}

.notif-time {
  font-size: 11px;
  color: var(--tx3);
  margin-top: 4px
}

/* ─── MODALS ─── */
.modal-ov {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(20, 8, 2, .55);
  backdrop-filter: blur(5px);
  z-index: 500;
  align-items: center;
  justify-content: center;
  padding: 16px
}

.modal-ov.open {
  display: flex
}

.modal {
  background: var(--wh);
  border-radius: 20px;
  width: 100%;
  max-width: 520px;
  max-height: 92vh;
  overflow-y: auto;
  box-shadow: 0 32px 80px rgba(0, 0, 0, .28);
  animation: mIn .25s cubic-bezier(.34, 1.4, .64, 1)
}

.modal-wide {
  max-width: 700px
}

@keyframes mIn {
  from {
    transform: scale(.92);
    opacity: 0
  }

  to {
    transform: scale(1);
    opacity: 1
  }
}

.modal-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 24px 0
}

.modal-hd h3 {
  font-family: 'Lora', serif;
  font-size: 20px;
  font-weight: 700;
  color: var(--br)
}

.mod-x {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: none;
  background: var(--bg2);
  color: var(--tx2);
  font-size: 18px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: .18s;
  flex-shrink: 0
}

