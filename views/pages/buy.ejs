<%- include('../partials/head', { title, headExtras: '', extraScript: '' }) %>
<style>
*,
*::before,
*::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --primary: #7B4B2A;
  --primary-dark: #5A361D;
  --primary-light: #C9A27A;
  --bg: #F7F3EE;
  --bg-soft: #EFE6DB;
  --bg3: #E5D8C8;
  --border: #E2D3C3;
  --text: #231209;
  --muted: #7A5C48;
  --wh: #fff;
}

body {
  font-family: 'Sora', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
}

/* NAV */
.nav {
  background: rgba(255, 255, 255, .92);
  backdrop-filter: blur(14px);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  padding: 0 28px;
  height: 60px;
  gap: 14px;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-logo {
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 10px;
}

.nav-logo-icon {
  width: 34px;
  height: 34px;
  border-radius: 9px;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  font-weight: 800;
  font-size: 17px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-logo b {
  font-size: 17px;
  font-weight: 800;
  color: var(--primary);
  display: block;
  line-height: 1.1;
}

.nav-logo small {
  font-size: 10px;
  color: var(--muted);
  display: block;
}

.back-btn {
  margin-left: auto;
  font-size: 13px;
  font-weight: 600;
  color: var(--primary);
  text-decoration: none;
  padding: 7px 14px;
  background: var(--bg-soft);
  border: 1.5px solid var(--border);
  border-radius: 9px;
  transition: .2s;
}

.back-btn:hover {
  background: var(--bg3);
}

/* LAYOUT */
.container {
  max-width: 1100px;
  margin: 36px auto;
  padding: 0 28px;
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 32px;
  animation: fadeUp .4s ease;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(16px)
  }

  to {
    opacity: 1;
    transform: translateY(0)
  }
}

/* IMAGE */
.product-image {
  position: relative;
  border-radius: 20px;
  overflow: hidden;
  background: var(--bg-soft);
  border: 1.5px solid var(--border);
}

#productImage {
  width: 100%;
  height: 420px;
  object-fit: cover;
  display: block;
  transition: .4s;
}

.product-image:hover #productImage {
  transform: scale(1.03);
}

/* INFO CARD */
.info-card {
  background: var(--wh);
  border-radius: 20px;
  padding: 28px;
  border: 1.5px solid var(--border);
  box-shadow: 0 8px 32px rgba(43, 27, 18, .08);
  display: flex;
  flex-direction: column;
  gap: 0;
}

.info-badge {
  display: inline-block;
  background: var(--bg-soft);
  color: var(--primary);
  border: 1px solid var(--border);
  padding: 4px 12px;
  border-radius: 99px;
  font-size: 11px;
  font-weight: 700;
  margin-bottom: 12px;
}

.info-card h2 {
  font-size: 24px;
  font-weight: 800;
  margin-bottom: 10px;
  line-height: 1.25;
}

.price {
  font-size: 32px;
  font-weight: 800;
  color: var(--primary);
  margin-bottom: 22px;
}

/* META */
.meta {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 24px;
}

.meta-row {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 12px 14px;
}

.mi {
  font-size: 18px;
  flex-shrink: 0;
  margin-top: 1px;
}

.ml {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .4px;
  color: var(--muted);
  margin-bottom: 3px;
}

.mv {
  font-size: 13px;
  font-weight: 500;
  line-height: 1.6;
}

/* BUTTONS */
.btn {
  width: 100%;
  padding: 14px;
  border: none;
  border-radius: 12px;
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
  font-family: 'Sora', sans-serif;
  transition: .25s;
}

.contact {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  box-shadow: 0 6px 20px rgba(123, 75, 42, .3);
  margin-bottom: 12px;
}

.contact:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 10px 28px rgba(123, 75, 42, .4);
}

.contact:disabled {
  opacity: .7;
  cursor: not-allowed;
}

.status-msg {
  padding: 12px 16px;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 500;
}

.status-msg.pending {
  background: #FEF3DC;
  color: #A06B10;
  border: 1px solid #F9D876;
}

.status-msg.accepted {
  background: #E8F5ED;
  color: #276840;
  border: 1px solid #A3D4B2;
}

.status-msg.accepted a {
  color: #276840;
  font-weight: 700;
}

.own-listing {
  background: var(--bg-soft);
  color: var(--muted);
  padding: 12px 16px;
  border-radius: 10px;
  font-size: 13px;
  text-align: center;
  border: 1px solid var(--border);
}

/* LOADING */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 14px;
  color: var(--muted);
  font-size: 14px;
}

.spinner {
  width: 36px;
  height: 36px;
  border: 3px solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg)
  }
}

@media(max-width:900px) {
  .container {
    grid-template-columns: 1fr;
  }

  #productImage {
    height: 280px;
  }
}

/* ═══════════════════════════════════════════
   RESPONSIVE ENHANCEMENTS — buy.css
═══════════════════════════════════════════ */
@media (max-width: 900px) {
  .container {
    grid-template-columns: 1fr;
    gap: 20px;
    margin: 20px auto;
    padding: 0 16px;
  }

  #productImage {
    height: 260px;
  }

  .info-card {
    padding: 20px;
  }

  .info-card h2 {
    font-size: 20px;
  }

  .price {
    font-size: 26px;
    margin-bottom: 16px;
  }

  .nav {
    padding: 0 16px;
    height: 54px;
  }

  .nav-logo b {
    font-size: 15px;
  }

  .nav-logo small {
    display: none;
  }

  .back-btn {
    padding: 6px 12px;
    font-size: 12px;
  }

  .meta-row {
    padding: 10px 12px;
  }

  .mi {
    font-size: 16px;
  }

  .mv {
    font-size: 12px;
  }

  .btn {
    padding: 12px;
    font-size: 13px;
  }
}

@media (max-width: 480px) {
  .container {
    margin: 12px auto;
    padding: 0 12px;
    gap: 14px;
  }

  #productImage {
    height: 220px;
    border-radius: 14px;
  }

  .info-card {
    padding: 16px;
    border-radius: 14px;
  }

  .info-card h2 {
    font-size: 18px;
  }

  .price {
    font-size: 22px;
  }

  .meta {
    gap: 8px;
  }

  .meta-row {
    border-radius: 8px;
    padding: 9px 11px;
  }
}
</style>

<nav class="nav">
    <a href="/marketplace" class="nav-logo">
      <div class="nav-logo-icon">S</div>
      <div>
        <b>StudXchange</b>
        <small>Academic Marketplace</small>
      </div>
    </a>
    <a href="/marketplace" class="back-btn">← Back</a>
  </nav>

  <div class="container" id="mainContainer" style="display:none">

    <div class="product-image">
      <img id="productImage" alt="Product Image">
      <div class="img-overlay"></div>
    </div>

    <div class="info-card">
      <div class="info-badge" id="categoryBadge"></div>
      <h2 id="title"></h2>
      <div class="price" id="price"></div>
      <div class="meta">
        <div class="meta-row" id="sellerRow"></div>
        <div class="meta-row" id="conditionRow"></div>
        <div class="meta-row" id="descRow"></div>
      </div>
      <button class="btn contact" id="chatBtn">💬 Request Chat</button>
      <div id="chatStatus"></div>
    </div>

  </div>

  <div class="loading-state" id="loadingState">
    <div class="spinner"></div>
    <p>Loading product…</p>
  </div>

<script>

const user   = JSON.parse(localStorage.getItem("user"));
const params = new URLSearchParams(window.location.search);
const id     = params.get("id");

if (!id) { alert("No product selected"); location.href="/marketplace"; }

async function loadProduct() {
  try {
    const res  = await fetch(`/product/${id}`);
    const data = await res.json();
    if (!data) { alert("Product not found"); location.href="/marketplace"; return; }

    document.getElementById("loadingState").style.display    = "none";
    document.getElementById("mainContainer").style.display   = "grid";

    document.getElementById("productImage").src             = data.image || "https://via.placeholder.com/500x400?text=No+Image";
    document.getElementById("title").textContent            = data.title;
    document.getElementById("price").textContent            = "₹" + Number(data.price).toLocaleString('en-IN');
    document.getElementById("categoryBadge").textContent    = "🏷 " + data.category;
    document.getElementById("sellerRow").innerHTML          = `<span class="mi">👤</span><div><div class="ml">Seller</div><div class="mv">${data.seller_name}</div></div>`;
    document.getElementById("conditionRow").innerHTML       = `<span class="mi">📦</span><div><div class="ml">Condition</div><div class="mv">${data.condition_type||"—"}</div></div>`;
    document.getElementById("descRow").innerHTML            = data.description ? `<span class="mi">📝</span><div><div class="ml">Description</div><div class="mv">${data.description}</div></div>` : "";

    const btn       = document.getElementById("chatBtn");
    const statusDiv = document.getElementById("chatStatus");

    if (user && data.seller_id && String(getUserId(user)) === String(data.seller_id)) {
      btn.style.display = "none";
      statusDiv.innerHTML = `<div class="own-listing">✅ This is your listing</div>`;
      return;
    }

    if (user && data.seller_id) {
      try {
        const sr   = await fetch(`/chat-status/${getUserId(user)}/${data.seller_id}/${data._id||data.id}`);
        const sd   = await sr.json();
        if (sd.status === "pending") {
          btn.disabled=true; btn.textContent="Request Sent ⏳";
          statusDiv.innerHTML = `<div class="status-msg pending">Waiting for seller to accept your request.</div>`;
        } else if (sd.status === "accepted") {
          btn.disabled=true; btn.textContent="Chat Accepted ✅";
          statusDiv.innerHTML = `<div class="status-msg accepted">✅ Seller accepted! <a href="/chat">Open Chat →</a></div>`;
        }
      } catch {}
    }

    btn.onclick = () => {
      if (!user) { alert("Please login to send a chat request"); location.href="/login"; return; }
      if (!confirm("Send a chat request to the seller?")) return;
      btn.disabled=true; btn.textContent="Sending…";
      fetch("/send-chat-request", {
        method:"POST", headers:{ "Authorization": "Bearer " + getToken(),"Content-Type":"application/json"},
        body: JSON.stringify({ sender_id:getUserId(user), receiver_id:data.seller_id, product_id:data._id||data.id })
      }).then(r=>r.json()).then(result => {
        if (result.success) {
          btn.textContent="Request Sent ⏳";
          statusDiv.innerHTML=`<div class="status-msg pending">Waiting for seller to accept.</div>`;
        } else {
          alert(result.error || "Could not send request. Try again.");
          btn.disabled=false; btn.textContent="💬 Request Chat";
        }
      });
    };
  } catch {
    alert("Error loading product. Make sure server is running.");
    location.href="/marketplace";
  }
}

loadProduct();

</script>

<%- include('../partials/foot') %>
