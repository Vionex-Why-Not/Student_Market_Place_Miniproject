<%- include('../partials/head', { title, headExtras: '', extraScript: '' }) %>
<style>
*,
*::before,
*::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box
}

:root {
  --br: #7B4B2A;
  --brd: #5A361D;
  --brl: #C9A27A;
  --brp: #F0E4D6;
  --bg: #F7F3EE;
  --bg2: #EFE6DB;
  --bg3: #E5D8C8;
  --bor: #E2D3C3;
  --tx: #231209;
  --tx2: #6B4838;
  --tx3: #9C7B66;
  --wh: #fff;
  --teal: #0D9488;
  --teal-dark: #0F766E;
  --teal-light: #5EEAD4;
}

html {
  scroll-behavior: smooth
}

body {
  font-family: 'Sora', sans-serif;
  background: var(--bg);
  color: var(--tx);
  overflow-x: hidden
}

/* ══ NAV ══════════════════════════════════════════════════════ */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 200;
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 0 32px;
  height: 64px;
  background: rgba(247, 243, 238, .92);
  backdrop-filter: blur(18px);
  border-bottom: 1px solid var(--bor);
  transition: box-shadow .3s;
}

.nav.scrolled {
  box-shadow: 0 4px 24px rgba(43, 27, 18, .1)
}

.nav-logo {
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 10px
}

.nav-logo-icon {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: linear-gradient(135deg, var(--br), var(--brd));
  color: #fff;
  font-weight: 800;
  font-size: 18px;
  font-family: 'Lora', serif;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 12px rgba(123, 75, 42, .35);
}

.nav-logo-text b {
  display: block;
  font-size: 17px;
  font-weight: 800;
  color: var(--br);
  line-height: 1.1
}

.nav-logo-text small {
  font-size: 10px;
  color: var(--tx3)
}

.nav-links {
  display: flex;
  gap: 4px;
  margin-left: 20px
}

.nl {
  text-decoration: none;
  padding: 7px 13px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  color: var(--tx2);
  transition: .18s;
}

.nl:hover {
  background: var(--bg2);
  color: var(--br)
}

.nav-r {
  margin-left: auto;
  display: flex;
  gap: 10px;
  align-items: center
}

.btn-ghost {
  padding: 8px 18px;
  border-radius: 10px;
  border: 1.5px solid var(--bor);
  background: transparent;
  font-size: 13px;
  font-weight: 700;
  color: var(--br);
  cursor: pointer;
  font-family: 'Sora', sans-serif;
  transition: .2s;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
}

.btn-ghost:hover {
  background: var(--bg2)
}

.btn-main {
  padding: 9px 20px;
  border-radius: 10px;
  border: none;
  background: linear-gradient(135deg, var(--br), var(--brd));
  font-size: 13px;
  font-weight: 700;
  color: #fff;
  cursor: pointer;
  font-family: 'Sora', sans-serif;
  transition: .2s;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  box-shadow: 0 4px 14px rgba(123, 75, 42, .3);
}

.btn-main:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(123, 75, 42, .4)
}

/* Hamburger */
.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  cursor: pointer;
  padding: 6px;
  border-radius: 8px;
  background: var(--bg2);
  border: 1.5px solid var(--bor);
  margin-left: auto;
}

.hamburger span {
  display: block;
  width: 20px;
  height: 2px;
  background: var(--br);
  border-radius: 2px;
  transition: .3s
}

.hamburger.open span:nth-child(1) {
  transform: rotate(45deg) translate(5px, 5px)
}

.hamburger.open span:nth-child(2) {
  opacity: 0
}

.hamburger.open span:nth-child(3) {
  transform: rotate(-45deg) translate(5px, -5px)
}

.mobile-menu {
  display: none;
  position: fixed;
  top: 64px;
  left: 0;
  right: 0;
  background: rgba(247, 243, 238, .97);
  backdrop-filter: blur(18px);
  border-bottom: 1px solid var(--bor);
  padding: 16px;
  flex-direction: column;
  gap: 6px;
  z-index: 190;
}

.mobile-menu.open {
  display: flex
}

.mobile-menu a,
.mobile-menu button {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 13px 16px;
  border-radius: 10px;
  text-decoration: none;
  font-size: 14px;
  font-weight: 600;
  color: var(--tx);
  border: none;
  background: none;
  cursor: pointer;
  font-family: 'Sora', sans-serif;
  transition: .15s;
  width: 100%;
}

.mobile-menu a:hover,
.mobile-menu button:hover {
  background: var(--bg2)
}

.mobile-menu .mm-div {
  height: 1px;
  background: var(--bor);
  margin: 4px 0
}

.mobile-menu .mm-primary {
  background: linear-gradient(135deg, var(--br), var(--brd));
  color: #fff;
  border-radius: 10px;
  justify-content: center;
}

.mobile-menu .mm-primary:hover {
  opacity: .92
}

/* ══ HERO ══════════════════════════════════════════════════════ */
.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  background: linear-gradient(145deg, #F7F3EE 0%, #EFE6DB 50%, #E5D8C8 100%);
  padding-top: 64px;
}

/* Decorative background shapes */
.hero-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden
}

.hb1 {
  position: absolute;
  width: 600px;
  height: 600px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(201, 162, 122, .35), transparent 70%);
  top: -100px;
  right: -100px;
  animation: pulse1 8s ease-in-out infinite;
}

.hb2 {
  position: absolute;
  width: 400px;
  height: 400px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(13, 148, 136, .12), transparent 70%);
  bottom: -80px;
  left: -60px;
  animation: pulse2 10s ease-in-out infinite;
}

.hb3 {
  position: absolute;
  width: 200px;
  height: 200px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(123, 75, 42, .12), transparent 70%);
  top: 40%;
  left: 45%;
  animation: pulse1 6s ease-in-out infinite reverse;
}

/* Floating emoji particles */
.particle {
  position: absolute;
  font-size: 28px;
  opacity: 0.12;
  animation: drift var(--d, 8s) ease-in-out infinite;
  animation-delay: var(--dl, 0s);
}

.p1 {
  top: 15%;
  left: 6%;
  --d: 9s;
  --dl: 0s
}

.p2 {
  top: 25%;
  right: 8%;
  --d: 7s;
  --dl: 1.5s
}

.p3 {
  top: 65%;
  left: 12%;
  --d: 11s;
  --dl: 3s
}

.p4 {
  bottom: 20%;
  right: 14%;
  --d: 8.5s;
  --dl: 0.5s
}

.p5 {
  top: 45%;
  right: 4%;
  --d: 10s;
  --dl: 2s
}

.p6 {
  bottom: 35%;
  left: 4%;
  --d: 7.5s;
  --dl: 4s
}

@keyframes drift {

  0%,
  100% {
    transform: translateY(0) rotate(0deg)
  }

  50% {
    transform: translateY(-22px) rotate(6deg)
  }
}

@keyframes pulse1 {

  0%,
  100% {
    transform: scale(1)
  }

  50% {
    transform: scale(1.08)
  }
}

@keyframes pulse2 {

  0%,
  100% {
    transform: scale(1)
  }

  50% {
    transform: scale(1.12)
  }
}

/* Diagonal divider */
.hero::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 0;
  right: 0;
  height: 80px;
  background: var(--wh);
  clip-path: polygon(0 100%, 100% 0, 100% 100%);
}

.hero-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 60px 32px;
  display: grid;
  grid-template-columns: 1fr 420px;
  gap: 60px;
  align-items: center;
  position: relative;
  z-index: 1;
  width: 100%;
}

/* Left text */
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--wh);
  border: 1.5px solid var(--bor);
  padding: 6px 14px;
  border-radius: 99px;
  font-size: 12px;
  font-weight: 700;
  color: var(--br);
  margin-bottom: 22px;
  box-shadow: 0 2px 12px rgba(43, 27, 18, .08);
  animation: fadeUp .5s ease both;
}

.badge-dot {
  width: 7px;
  height: 7px;
  background: #4CAF74;
  border-radius: 50%;
  box-shadow: 0 0 6px #4CAF74
}

.hero-title {
  font-family: 'Lora', serif;
  font-size: clamp(36px, 5vw, 60px);
  font-weight: 700;
  line-height: 1.15;
  color: var(--tx);
  margin-bottom: 18px;
  animation: fadeUp .5s .1s ease both;
}

.hero-title em {
  color: var(--br);
  font-style: italic
}

.hero-title .teal {
  color: var(--teal)
}

.hero-sub {
  font-size: clamp(14px, 1.8vw, 17px);
  color: var(--tx2);
  line-height: 1.7;
  max-width: 480px;
  margin-bottom: 36px;
  animation: fadeUp .5s .2s ease both;
}

.hero-actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  animation: fadeUp .5s .3s ease both;
}

.hero-btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 9px;
  padding: 14px 28px;
  border-radius: 13px;
  background: linear-gradient(135deg, var(--br), var(--brd));
  color: #fff;
  font-size: 15px;
  font-weight: 700;
  text-decoration: none;
  font-family: 'Sora', sans-serif;
  box-shadow: 0 6px 24px rgba(123, 75, 42, .35);
  transition: .25s cubic-bezier(.34, 1.2, .64, 1);
}

.hero-btn-primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 32px rgba(123, 75, 42, .45)
}

.hero-btn-secondary {
  display: inline-flex;
  align-items: center;
  gap: 9px;
  padding: 14px 28px;
  border-radius: 13px;
  background: var(--wh);
  border: 2px solid var(--bor);
  color: var(--tx);
  font-size: 15px;
  font-weight: 700;
  text-decoration: none;
  font-family: 'Sora', sans-serif;
  transition: .25s cubic-bezier(.34, 1.2, .64, 1);
}

.hero-btn-secondary:hover {
  border-color: var(--brl);
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(43, 27, 18, .1)
}

.hero-stats {
  display: flex;
  gap: 28px;
  margin-top: 44px;
  animation: fadeUp .5s .4s ease both;
}

.hstat {
  display: flex;
  flex-direction: column;
  gap: 2px
}

.hstat-num {
  font-family: 'Lora', serif;
  font-size: 28px;
  font-weight: 700;
  color: var(--br);
  line-height: 1
}

.hstat-lbl {
  font-size: 11px;
  color: var(--tx3);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: .5px
}

.hstat-div {
  width: 1px;
  height: 36px;
  background: var(--bor);
  align-self: center
}

/* Right: Feature cards stack */
.hero-cards {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 14px;
  animation: fadeUp .5s .35s ease both;
}

.hero-card {
  background: var(--wh);
  border: 1.5px solid var(--bor);
  border-radius: 18px;
  padding: 18px 20px;
  display: flex;
  align-items: center;
  gap: 14px;
  text-decoration: none;
  color: var(--tx);
  box-shadow: 0 4px 20px rgba(43, 27, 18, .07);
  transition: .28s cubic-bezier(.34, 1.2, .64, 1);
  position: relative;
  overflow: hidden;
}

.hero-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4px;
  background: linear-gradient(180deg, var(--br), var(--brl));
  border-radius: 4px 0 0 4px;
}

.hero-card.teal::before {
  background: linear-gradient(180deg, var(--teal), var(--teal-light))
}

.hero-card.amber::before {
  background: linear-gradient(180deg, #D97706, #F59E0B)
}

.hero-card:hover {
  transform: translateX(6px) translateY(-2px);
  box-shadow: 0 10px 32px rgba(43, 27, 18, .14);
  border-color: var(--brl)
}

.hero-card.teal:hover {
  border-color: #99F6E4
}

.hero-card.amber:hover {
  border-color: #FCD34D
}

.hc-icon {
  width: 46px;
  height: 46px;
  border-radius: 12px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  background: var(--bg2);
}

.hero-card.teal .hc-icon {
  background: rgba(13, 148, 136, .1)
}

.hero-card.amber .hc-icon {
  background: rgba(217, 119, 6, .1)
}

.hc-body {
  flex: 1;
  min-width: 0
}

.hc-title {
  font-size: 14px;
  font-weight: 700;
  margin-bottom: 3px
}

.hc-sub {
  font-size: 12px;
  color: var(--tx3)
}

.hc-arrow {
  font-size: 18px;
  color: var(--bor);
  transition: .3s;
  flex-shrink: 0
}

.hero-card:hover .hc-arrow {
  color: var(--br);
  transform: translateX(4px)
}

.hero-card.teal:hover .hc-arrow {
  color: var(--teal)
}

.hero-card.amber:hover .hc-arrow {
  color: #D97706
}

/* No login badge */
.no-login-note {
  margin-top: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: var(--tx3);
  font-weight: 500;
  padding: 10px 14px;
  background: var(--bg);
  border: 1px solid var(--bor);
  border-radius: 10px;
}

.no-login-note span {
  font-size: 16px
}

/* ══ SECTION SHARED ════════════════════════════════════════════ */
section {
  padding: 96px 32px;
  position: relative
}

.sec-inner {
  max-width: 1100px;
  margin: 0 auto
}

.sec-label {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--br);
  margin-bottom: 14px;
}

.sec-label::after {
  content: '';
  display: block;
  width: 32px;
  height: 2px;
  background: var(--brl);
  border-radius: 2px
}

.sec-title {
  font-family: 'Lora', serif;
  font-size: clamp(26px, 3.5vw, 40px);
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 14px;
  color: var(--tx);
}

.sec-sub {
  font-size: 15px;
  color: var(--tx2);
  line-height: 1.7;
  max-width: 560px
}

/* ══ HOW IT WORKS ══════════════════════════════════════════════ */
.how {
  background: var(--wh)
}

.steps {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
  margin-top: 56px;
  position: relative;
}

.steps::before {
  content: '';
  position: absolute;
  top: 32px;
  left: calc(16.66% + 16px);
  right: calc(16.66% + 16px);
  height: 2px;
  background: linear-gradient(90deg, var(--bor), var(--brl), var(--bor));
  border-radius: 2px;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 0
}

.step-num {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--br), var(--brd));
  color: #fff;
  font-family: 'Lora', serif;
  font-size: 24px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 24px rgba(123, 75, 42, .3);
  margin-bottom: 20px;
  position: relative;
  z-index: 1;
}

.step-icon {
  font-size: 28px;
  margin-bottom: 14px
}

.step-title {
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 8px;
  color: var(--tx)
}

.step-desc {
  font-size: 13px;
  color: var(--tx2);
  line-height: 1.65
}

/* ══ FEATURES ══════════════════════════════════════════════════ */
.features-bg {
  background: linear-gradient(135deg, #2C1208 0%, var(--brd) 50%, #3D1A0A 100%);
  position: relative;
  overflow: hidden;
}

.features-bg::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 60% 80% at 10% 60%, rgba(201, 162, 122, .1), transparent 60%),
    radial-gradient(ellipse 50% 60% at 90% 20%, rgba(13, 148, 136, .08), transparent 60%);
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-top: 56px;
  position: relative;
  z-index: 1;
}

.feat-card {
  background: rgba(255, 255, 255, .07);
  border: 1px solid rgba(255, 255, 255, .1);
  border-radius: 18px;
  padding: 26px 22px;
  backdrop-filter: blur(8px);
  transition: .25s;
}

.feat-card:hover {
  background: rgba(255, 255, 255, .12);
  transform: translateY(-4px)
}

.feat-icon {
  font-size: 32px;
  margin-bottom: 14px
}

.feat-title {
  font-size: 16px;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8px
}

.feat-desc {
  font-size: 13px;
  color: rgba(255, 255, 255, .65);
  line-height: 1.65
}

.features-bg .sec-label {
  color: var(--brl)
}

.features-bg .sec-label::after {
  background: var(--brl)
}

.features-bg .sec-title {
  color: #fff
}

.features-bg .sec-sub {
  color: rgba(255, 255, 255, .7)
}

/* ══ EXPLORE SECTION ═══════════════════════════════════════════ */
.explore {
  background: var(--bg)
}

.explore-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-top: 48px;
}

.exp-card {
  border-radius: 20px;
  padding: 32px 26px;
  text-decoration: none;
  display: flex;
  flex-direction: column;
  gap: 12px;
  border: 2px solid var(--bor);
  position: relative;
  overflow: hidden;
  transition: .3s cubic-bezier(.34, 1.2, .64, 1);
  background: var(--wh);
}

.exp-card::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--br), var(--brl));
  transform: scaleX(0);
  transition: .3s;
  transform-origin: left;
}

.exp-card.teal::after {
  background: linear-gradient(90deg, var(--teal), var(--teal-light))
}

.exp-card.amber::after {
  background: linear-gradient(90deg, #D97706, #F59E0B)
}

.exp-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 16px 48px rgba(43, 27, 18, .14);
  border-color: var(--brl)
}

.exp-card.teal:hover {
  border-color: #99F6E4
}

.exp-card.amber:hover {
  border-color: #FCD34D
}

.exp-card:hover::after {
  transform: scaleX(1)
}

.exp-icon {
  font-size: 40px
}

.exp-badge {
  align-self: flex-start;
  font-size: 10px;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 99px;
  background: var(--bg2);
  color: var(--tx2);
  border: 1px solid var(--bor);
}

.exp-card.teal .exp-badge {
  background: rgba(13, 148, 136, .1);
  color: var(--teal);
  border-color: rgba(13, 148, 136, .2)
}

.exp-card.amber .exp-badge {
  background: rgba(217, 119, 6, .1);
  color: #B45309;
  border-color: rgba(217, 119, 6, .2)
}

.exp-title {
  font-family: 'Lora', serif;
  font-size: 22px;
  font-weight: 700;
  color: var(--tx)
}

.exp-card.teal .exp-title {
  color: var(--teal-dark)
}

.exp-card.amber .exp-title {
  color: #92400E
}

.exp-desc {
  font-size: 13px;
  color: var(--tx2);
  line-height: 1.65
}

.exp-cta {
  margin-top: auto;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  font-weight: 700;
  color: var(--br);
}

.exp-card.teal .exp-cta {
  color: var(--teal)
}

.exp-card.amber .exp-cta {
  color: #D97706
}

.exp-cta-arrow {
  transition: .3s
}

.exp-card:hover .exp-cta-arrow {
