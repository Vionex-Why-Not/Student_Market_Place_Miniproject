<%- include('../partials/head', { title: title || 'Error', headExtras: '', extraScript: '' }) %>
<style>
body { font-family: 'Sora', sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; background: #F7F3EE; color: #231209; }
.box { text-align: center; padding: 40px; }
.code { font-size: 72px; font-weight: 800; color: #7B4B2A; margin-bottom: 12px; }
h1 { font-size: 24px; margin-bottom: 10px; }
p { color: #9C7B66; margin-bottom: 24px; }
a { background: linear-gradient(135deg,#7B4B2A,#5A361D); color: #fff; padding: 12px 28px; border-radius: 10px; text-decoration: none; font-weight: 700; }
</style>
<div class="box">
  <div class="code"><%= status || 500 %></div>
  <h1>Oops!</h1>
  <p><%= message || 'Something went wrong.' %></p>
  <a href="/">← Back to Home</a>
</div>
<%- include('../partials/foot') %>
